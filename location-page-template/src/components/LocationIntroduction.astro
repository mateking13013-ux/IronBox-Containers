---
interface Props {
  title: string;
  paragraph1: string;
  paragraph2?: string;
  locationName: string;
}

const { title, paragraph1, paragraph2, locationName } = Astro.props;

import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { CheckCircle, Shield, DollarSign, Truck, Wrench, Star, MapPin, Globe, Users, Leaf, Package } from 'lucide-react';
---

<!-- Introduction Content Section -->
<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="prose prose-lg max-w-none">
      <h2 class="text-3xl font-bold mb-6">{title}</h2>
      
      <p class="text-muted-foreground mb-4">
        {paragraph1}
      </p>
      
      {paragraph2 && (
        <p class="text-muted-foreground mb-4">
          {paragraph2}
        </p>
      )}
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
        <div class="space-y-4">
          <h3 class="text-xl font-semibold flex items-center gap-2">
            <CheckCircle className="h-5 w-5 text-green-500" />
            Why Choose Our Containers?
          </h3>
          <ul class="space-y-2">
            <li class="flex items-start gap-2">
              <Shield className="h-4 w-4 text-primary mt-1" />
              <span>100% inspected and certified for quality and safety</span>
            </li>
            <li class="flex items-start gap-2">
              <DollarSign className="h-4 w-4 text-primary mt-1" />
              <span>Competitive pricing with flexible payment options</span>
            </li>
            <li class="flex items-start gap-2">
              <Truck className="h-4 w-4 text-primary mt-1" />
              <span>Fast delivery throughout {locationName}</span>
            </li>
            <li class="flex items-start gap-2">
              <Wrench className="h-4 w-4 text-primary mt-1" />
              <span>Customization options available</span>
            </li>
          </ul>
        </div>
        
        <div class="space-y-4">
          <h3 class="text-xl font-semibold flex items-center gap-2">
            <Star className="h-5 w-5 text-yellow-500" />
            Popular Uses in {locationName}
          </h3>
          <ul class="space-y-2">
            <li class="flex items-start gap-2">
              <Users className="h-4 w-4 text-primary mt-1" />
              <span>Residential storage solutions</span>
            </li>
            <li class="flex items-start gap-2">
              <Globe className="h-4 w-4 text-primary mt-1" />
              <span>Commercial inventory storage</span>
            </li>
            <li class="flex items-start gap-2">
              <Leaf className="h-4 w-4 text-primary mt-1" />
              <span>Container homes and offices</span>
            </li>
            <li class="flex items-start gap-2">
              <Package className="h-4 w-4 text-primary mt-1" />
              <span>International shipping and logistics</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>