---
export const prerender = false; // SSR mode for real-time WordPress data

interface WordPressPage {
  id: number;
  title: { rendered: string };
  slug: string;
  acf: any;
}

interface LocationData {
  location_name: string;
  location_state: string;
  location_country: string;
  hero_headline: string;
  hero_subheadline: string;
  hero_cta_primary_text: string;
  hero_cta_secondary_text: string;
  intro_title: string;
  intro_paragraph_1: string;
  intro_paragraph_2: string;
  container_products: Array<{
    product_name: string;
    product_description: string;
    product_price: string;
    product_features: Array<string>;
  }>;
  faq_items: Array<{
    faq_question: string;
    faq_answer: string;
  }>;
  phone_number: string;
  email_address: string;
  business_hours: string;
  service_area_text: string;
  seo_title: string;
  seo_description: string;
}

const { slug } = Astro.params;

// Fetch data from WordPress
const response = await fetch(`https://your-wp-site.com/wp-json/wp/v2/location_pages?slug=${slug}&_embed=acf`);
const pages: WordPressPage[] = await response.json();
const page = pages[0];

// If page not found, show 404
if (!page) {
  return Astro.response.status = 404;
}

const acf: LocationData = page.acf;

// Import components
import LocationLayout from '../../layouts/LocationLayout.astro';
import LocationHero from '../../components/LocationHero.astro';
import LocationIntroduction from '../../components/LocationIntroduction.astro';
import LocationProducts from '../../components/LocationProducts.astro';
import LocationFAQ from '../../components/LocationFAQ.astro';
import LocationCTA from '../../components/LocationCTA.astro';
---

<LocationLayout 
  title={acf.seo_title || `${acf.location_name} Shipping Containers`}
  description={acf.seo_description}
  locationName={acf.location_name}
>
  <!-- Hero Section -->
  <LocationHero 
    headline={acf.hero_headline}
    subheadline={acf.hero_subheadline}
    primaryCTAText={acf.hero_cta_primary_text}
    secondaryCTAText={acf.hero_cta_secondary_text}
    serviceAreaText={acf.service_area_text}
    locationName={acf.location_name}
  />

  <!-- Introduction Section -->
  <LocationIntroduction 
    title={acf.intro_title}
    paragraph1={acf.intro_paragraph_1}
    paragraph2={acf.intro_paragraph_2}
    locationName={acf.location_name}
  />

  <!-- Products Section -->
  <LocationProducts 
    products={acf.container_products}
    locationName={acf.location_name}
  />

  <!-- FAQ Section -->
  <LocationFAQ 
    faqItems={acf.faq_items}
    locationName={acf.location_name}
  />

  <!-- CTA Section -->
  <LocationCTA 
    locationName={acf.location_name}
    phoneNumber={acf.phone_number}
  />
</LocationLayout>