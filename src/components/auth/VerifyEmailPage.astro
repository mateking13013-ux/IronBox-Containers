<section class="flex min-h-screen items-center justify-center bg-muted/40 px-4 py-12">
  <div class="w-full max-w-md rounded-3xl border border-border bg-card p-8 text-center shadow-lg">
    <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-6.9 4.143a2.25 2.25 0 01-2.26 0L3.57 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
    </div>
    <h1 class="mt-4 text-2xl font-semibold text-foreground">Check your inbox</h1>
    <p class="mt-2 text-sm text-muted-foreground">We sent a verification link to <span class="font-semibold text-foreground">alex.morgan@example.com</span>. Click the link within 24 hours to activate your account.</p>

    <div class="mt-6 space-y-4 text-sm text-muted-foreground">
      <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 text-left text-blue-800">
        <p class="font-semibold">Having trouble finding it?</p>
        <ul class="mt-2 list-disc space-y-1 pl-5 text-xs">
          <li>Look in your spam or promotions folder</li>
          <li>Add info@ironboxcontainers.co.za to your safe senders list</li>
          <li>Permit team emails will come from this address too</li>
        </ul>
      </div>

      <button class="w-full rounded-full border border-border px-6 py-3 text-sm font-semibold text-foreground transition hover:bg-muted">Resend verification email</button>
      <a href="/shop" class="flex w-full items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">Continue shopping <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg></a>
    </div>

    <p class="mt-6 text-xs text-muted-foreground">You may close this page after verifying your email.</p>
  </div>
</section>
