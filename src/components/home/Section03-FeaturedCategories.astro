---
import { getCategories } from '../../lib/woocommerce.js';
const allCategories = await getCategories();

const categoryDescriptions: Record<string, string> = {
  '10-ft-used-shipping-containers': 'Compact storage ideal for tight spaces and residential yards.',
  '10ft-new-shipping-containers': 'Brand new 10ft units, perfect for secure on-site storage.',
  '20ft-used-shipping-containers': 'Our most popular size for general storage and conversions.',
  '20ft-new-shipping-containers': 'One-trip 20ft containers in pristine condition.',
  '40ft-new-shipping-containers': 'Maximum storage capacity with factory-fresh quality.',
  '40ft-used-shipping-containers': 'Cost-effective large-scale storage and warehouse solutions.',
  'high-cube-shipping-containers': 'Extra height for oversized cargo and comfortable living spaces.',
  'refrigerated-shipping-containers': 'Temperature-controlled units for cold chain and perishables.',
  'guard-booths-shacks-houses': 'Prefab security booths, guard shacks, and modular houses.',
  'modified-containers': 'Custom-built container homes, offices, and specialty conversions.',
  'portable-site-office-containers': 'Turnkey mobile offices ready for construction and events.',
  'flat-pack-shipping-containers': 'Flat-pack units that ship affordably and assemble on site.',
  'plastic-drums-and-ibc-totes': 'Industrial drums and IBC totes for liquid storage and transport.',
  'plastic-pallets': 'Heavy-duty plastic pallets for warehousing and logistics.',
};
---

<section class="w-full bg-white py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <h2 class="text-2xl font-bold text-gray-900 sm:text-3xl">Shop by Category</h2>
      <p class="mt-2 text-sm text-gray-500">Browse our full range of containers and industrial supplies</p>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 sm:gap-4">
      {allCategories.map((cat) => (
        <a href={`/categories/${cat.slug}`} class="group relative overflow-hidden rounded-xl border border-gray-100 bg-white transition-all duration-200 hover:shadow-lg hover:border-gray-200">
          <div class="aspect-[4/3] overflow-hidden bg-gray-50">
            <img
              src={cat.image?.src || '/images/product-placeholder.jpg'}
              alt={cat.name}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>
          <div class="p-3 sm:p-4">
            <h3 class="text-xs sm:text-sm font-semibold text-gray-900 leading-snug group-hover:text-blue-600 transition-colors">
              {cat.name}
            </h3>
            <p class="mt-1 text-[11px] sm:text-xs text-gray-500 leading-relaxed line-clamp-2">
              {categoryDescriptions[cat.slug] || `${cat.count} products available`}
            </p>
            <div class="mt-2 flex items-center justify-between">
              <span class="text-[10px] sm:text-[11px] font-medium text-gray-400">{cat.count} products</span>
              <svg class="h-3.5 w-3.5 text-gray-300 transition-colors group-hover:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
