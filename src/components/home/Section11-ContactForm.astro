---
const section = {
  title: 'Get In Touch',
  description: 'Have questions about our container solutions? Let\'s discuss your project needs.',
  contactInfo: {
    phone: '+1 (555) 123-4567',
    email: 'info@ironboxcontainers.co.za',
    address: '123 Commerce Rd, Industrial Park, CA 90210',
    hours: 'Mon-Fri: 8AM-6PM PST'
  },
  socialLinks: [
    { name: 'Facebook', icon: 'facebook', href: '#' },
    { name: 'Twitter', icon: 'twitter', href: '#' },
    { name: 'Instagram', icon: 'instagram', href: '#' },
    { name: 'LinkedIn', icon: 'linkedin', href: '#' }
  ]
};

const iconMap = {
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  twitter: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`
};
---

<section class="w-full bg-muted/30 py-16">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold text-foreground">{section.title}</h2>
      <p class="text-lg text-muted-foreground">{section.description}</p>
    </div>
    
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Contact Form -->
      <div class="rounded-2xl bg-white p-8 shadow-lg border border-gray-200">
        <form class="space-y-6" method="POST" action="/contact" id="contact-form">
          <div class="grid gap-6 md:grid-cols-2">
            <div>
              <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
                First Name
              </label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                placeholder="John"
              />
            </div>
            <div>
              <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
                Last Name
              </label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                placeholder="Doe"
              />
            </div>
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Email Address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
              placeholder="john@example.com"
            />
          </div>
          
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Phone Number
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
              placeholder="+1 (555) 123-4567"
            />
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
              Subject
            </label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
            >
              <option value="">Select a topic</option>
              <option value="general">General Inquiry</option>
              <option value="pool">Container Pools</option>
              <option value="home">Prefab Homes</option>
              <option value="storage">Storage Solutions</option>
              <option value="commercial">Commercial Projects</option>
              <option value="support">Customer Support</option>
            </select>
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 placeholder-gray-500 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-none"
              placeholder="Tell us about your project needs..."
            ></textarea>
          </div>
          
          <button
            type="submit"
            class="w-full rounded-lg bg-primary px-8 py-4 text-lg font-semibold text-primary-foreground transition hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2"
          >
            Send Message
          </button>
        </form>
      </div>
      
      <!-- Contact Information -->
      <div class="space-y-8">
        <!-- Quick Contact Info -->
        <div class="rounded-2xl bg-white p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-foreground mb-6">Get in Touch</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="rounded-full bg-primary/10 p-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75C2.25 15.75 9 22.5 18 22.5c1.892 0 3.68-.246 5.23-.687a2.25 2.25 0 001.597-1.597c.441-1.55.687-3.338.687-5.23C24.75 9 18 2.25 9 2.25c-1.892 0-3.68.247-5.23.688a2.25 2.25 0 00-1.597 1.597C1.632 5.32 1.383 7.108 1.383 9c0 1.892.247 3.68.688 5.23a2.25 2.25 0 001.597 1.597c1.55.44 3.338.687 5.23.687z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-600">Phone</p>
                <p class="font-medium text-foreground">{section.contactInfo.phone}</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="rounded-full bg-primary/10 p-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-600">Email</p>
                <p class="font-medium text-foreground">{section.contactInfo.email}</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="rounded-full bg-primary/10 p-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-600">Address</p>
                <p class="font-medium text-foreground">{section.contactInfo.address}</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="rounded-full bg-primary/10 p-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-600">Business Hours</p>
                <p class="font-medium text-foreground">{section.contactInfo.hours}</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Social Media -->
        <div class="rounded-2xl bg-white p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-foreground mb-6">Follow Us</h3>
          <div class="grid grid-cols-2 gap-4">
            {section.socialLinks.map((social) => (
              <a
                href={social.href}
                class="flex items-center gap-3 rounded-lg border border-gray-200 px-4 py-3 text-gray-700 transition hover:bg-gray-50 hover:border-gray-300"
              >
                <span class="text-gray-600" set:html={iconMap[social.icon]}></span>
                <span class="font-medium">{social.name}</span>
              </a>
            ))}
          </div>
        </div>
        
        <!-- Why Contact Us -->
        <div class="rounded-2xl bg-primary/5 p-6 border border-primary/20">
          <h3 class="text-lg font-semibold text-foreground mb-3">Why Choose Us?</h3>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Expert consultations for your specific needs</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Nationwide delivery and installation</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Competitive pricing and quality guarantee</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    alert('Thank you for your message! We will get back to you soon.');
    this.reset();
  });
</script>
