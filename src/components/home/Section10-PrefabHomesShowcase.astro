---
import { getAllProducts, formatPrice } from '../../lib/woocommerce.js';

// Get random products from WooCommerce for prefab homes showcase
const allProducts = await getAllProducts();
const randomProducts = allProducts.sort(() => 0.5 - Math.random()).slice(0, 3); // Get 3 random products

const section = {
  title: 'Prefab Container Homes',
  description: 'Sustainable living meets modern design with our container homes',
  cta: { label: 'all our containers', href: '/shop' },
};

// Helper function to generate ratings
function generateRating() {
  return (4.0 + Math.random() * 1.0).toFixed(1);
}
---

<section class="w-full bg-background py-16">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold text-foreground">{section.title}</h2>
      <p class="text-lg text-muted-foreground">{section.description}</p>
    </div>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {randomProducts.map((product) => {
        const imageUrl = product.images?.[0]?.src || 'https://via.placeholder.com/400x300';
        const description = product.short_description || product.description || 'Premium container solution for your needs';
        const rating = generateRating();
        
        return (
          <a href={`/products/${product.slug}`} class="group">
            <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition group-hover:shadow-xl">
              <div class="relative aspect-[4/3]">
                <img src={imageUrl} alt={product.name} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
                <div class="absolute top-6 right-6 rounded-full bg-white/10 p-3 backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" /></svg>
                </div>
                <div class="absolute bottom-6 left-6 right-6 space-y-3 text-white">
                  <h3 class="text-xl font-bold group-hover:text-primary">{product.name}</h3>
                  <p class="text-sm opacity-90">{description.replace(/<[^>]*>/g, '').substring(0, 100)}...</p>
                  <div class="flex items-center justify-between">
                    <span class="text-2xl font-bold">{formatPrice(product.price)}</span>
                    <div class="flex items-center gap-1 text-sm font-medium">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-warning" viewBox="0 0 24 24" fill="currentColor"><path d="M11.48 3.499a.75.75 0 011.04 0l2.56 2.401 3.38.49a.75.75 0 01.415 1.28l-2.447 2.384.578 3.366a.75.75 0 01-1.088.79L12 12.347l-3.038 1.597a.75.75 0 01-1.088-.79l.578-3.366L6.005 7.67a.75.75 0 01.415-1.28l3.38-.49 2.56-2.401z" /></svg>
                      {rating}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
    <div class="mt-12 text-center">
      <a href={section.cta.href} class="inline-flex items-center gap-2 rounded-lg bg-primary px-8 py-4 text-lg font-semibold text-primary-foreground transition hover:bg-primary/90">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12l-7.5 7.5M21 12H3" /></svg>
        {section.cta.label}
      </a>
    </div>
  </div>
</section>
