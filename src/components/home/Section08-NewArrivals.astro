---
const section = {
  title: 'New Arrivals',
  description: 'Fresh products just added to our store',
  cta: { label: 'View All New', href: '/shop?sort=newest' },
  products: [
    { name: 'Sunset Series Pool', price: 'R26,900', image: 'https://images.unsplash.com/photo-1545239351-1141bd82e8a6?auto=format&fit=crop&w=1200&q=80', href: '/products/sunset-series-pool' },
    { name: 'Studio ADU', price: 'R142,000', image: 'https://images.unsplash.com/photo-1600585154340-0ef3c08ba6b0?auto=format&fit=crop&w=1200&q=80', href: '/products/studio-adu' },
    { name: 'Site Office Pod', price: 'R18,750', image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=1200&q=80', href: '/products/site-office-pod' },
    { name: 'Event Restroom Duo', price: 'R14,950', image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=1200&q=80', href: '/products/event-restroom-duo' },
  ],
};
---

<section class="w-full bg-background py-16">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mb-12 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl font-bold text-foreground">{section.title}</h2>
        <p class="text-lg text-muted-foreground">{section.description}</p>
      </div>
      <a href={section.cta.href} class="inline-flex items-center gap-2 rounded border border-border px-4 py-2 text-sm font-medium text-foreground transition hover:bg-muted">
        {section.cta.label}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-2 md:gap-6 lg:grid-cols-4">
      {section.products.map((product) => (
        <a href={product.href} class="group">
          <div class="overflow-hidden rounded-2xl border border-border bg-card">
            <div class="relative aspect-[4/5]">
              <img src={product.image} alt={product.name} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
            </div>
            <div class="space-y-1 p-4">
              <h3 class="text-base font-semibold text-foreground group-hover:text-primary">{product.name}</h3>
              <p class="text-sm font-medium text-primary">{product.price}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
