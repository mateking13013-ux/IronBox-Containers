---

<section class="w-full py-16 bg-gray-900">
  <div class="max-w-full mx-auto px-4">
    <!-- Section Header -->
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Our Solutions</h2>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Transform your space with our innovative container products
      </p>
    </div>

    <!-- Simple Grid Layout - 2 Columns -->
    <div class="grid grid-cols-12 gap-4 lg:gap-6" style="min-height: 200px;">
      
      <!-- Section 1 - 70% width (left) -->
      <div class="col-span-7 md:col-span-7 bg-gradient-to-br from-blue-600 to-blue-800 rounded-2xl p-8 text-white shadow-lg hover:shadow-xl transition-shadow">
        <div class="h-full flex flex-col justify-center">
          <h3 class="text-2xl font-bold mb-4">Container Pools</h3>
          <p class="text-white/90 mb-6">Transform your backyard with our premium shipping container pools. Perfect for modern outdoor living spaces.</p>
          <div class="flex items-center gap-4">
            <div class="w-3 h-3 bg-white/80 rounded-full"></div>
            <span class="text-sm">Starting at R2,000</span>
          </div>
        </div>
      </div>

      <!-- Column 2 - smaller width -->
      <div class="col-span-4 md:col-span-4 bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl p-6 border border-gray-700 shadow-lg hover:shadow-xl transition-shadow">
        <div class="h-full flex flex-col justify-center">
          <h3 class="text-lg font-semibold mb-3 text-white">Tiny Homes</h3>
          <p class="text-gray-300 text-sm mb-4">Complete prefab homes with modern amenities and sustainable design.</p>
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
            <span class="text-xs text-gray-400">From R2,000</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Responsive Layout for Mobile -->
    <div class="mt-6 md:hidden space-y-4">
      <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-6 text-white">
        <h3 class="text-lg font-bold mb-2">Container Pools</h3>
        <p class="text-white/80 text-sm mb-3">Transform your backyard with premium container pools</p>
        <div class="text-white/60 text-xs">Starting at R2,000</div>
      </div>
      
      <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
        <h3 class="text-lg font-semibold mb-2 text-white">Tiny Homes</h3>
        <p class="text-gray-300 text-sm mb-3">Complete prefab homes with modern amenities</p>
        <div class="text-gray-400 text-xs">From R2,000</div>
      </div>
    </div>
  </div>
</section>
