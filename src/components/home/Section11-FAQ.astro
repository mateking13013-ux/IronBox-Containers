---
const section = {
  title: 'Frequently Asked Questions',
  description: 'Get answers to common questions',
  faqs: [
    {
      question: 'How long does installation take?',
      answer: 'Most container pools and prefab homes install in 6-8 weeks once permits and site prep are completed.',
    },
    {
      question: 'Do you ship nationwide?',
      answer: 'Yes. We have logistics partners and install crews across the contiguous United States.',
    },
    {
      question: 'Can I customize floor plans?',
      answer: 'Absolutely. Our design team can tailor layouts, finishes, and add-ons to match your project requirements.',
    },
    {
      question: 'What kind of warranty is included?',
      answer: 'Primary structures include a 10-year structural warranty plus manufacturer warranties on mechanical components.',
    },
  ],
};
---

<section class="w-full bg-muted/30 py-16">
  <div class="mx-auto max-w-4xl px-4">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold text-foreground">{section.title}</h2>
      <p class="text-lg text-muted-foreground">{section.description}</p>
    </div>
    <div class="space-y-4">
      {section.faqs.map((faq) => (
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-3 text-lg font-semibold text-foreground">{faq.question}</h3>
          <p class="text-muted-foreground">{faq.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
