---

<section class="w-full py-16 bg-gray-100">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Section Header -->
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Solutions</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Transform your space with our innovative container products
      </p>
    </div>

    <!-- Bento Grid Container -->
    <div class="flex flex-col gap-4">
      
      <!-- First Row: 70% and 30% columns, both 150px height -->
      <div class="flex gap-4">
        <div class="w-[70%] h-36 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center text-white font-bold text-center shadow-lg hover:shadow-xl transition-shadow">
          <div>
            <h3 class="text-xl mb-2">Container Pools</h3>
            <p class="text-sm opacity-90">Premium pool solutions</p>
          </div>
        </div>
        <div class="w-[30%] h-36 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center text-white font-bold text-center shadow-lg hover:shadow-xl transition-shadow">
          <div>
            <h3 class="text-lg mb-1">Tiny Homes</h3>
            <p class="text-xs opacity-90">Modern living</p>
          </div>
        </div>
      </div>
      
      <!-- Second Row: 30% and 70% columns, both 300px height -->
      <div class="flex gap-4">
        <div class="w-[30%] h-72 bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl flex items-center justify-center text-white font-bold text-center shadow-lg hover:shadow-xl transition-shadow">
          <div>
            <h3 class="text-lg mb-2">Storage Units</h3>
            <p class="text-sm opacity-90">Secure solutions</p>
          </div>
        </div>
        <div class="w-[70%] h-72 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center text-white font-bold text-center shadow-lg hover:shadow-xl transition-shadow">
          <div>
            <h3 class="text-2xl mb-3">Restroom Solutions</h3>
            <p class="text-base opacity-90 mb-4">Portable and permanent restroom solutions for events and construction sites</p>
            <div class="inline-block bg-white/20 px-4 py-2 rounded-lg">
              <span class="text-sm">Starting at $3,500</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Mobile Responsive Layout -->
    <div class="md:hidden mt-6 space-y-4">
      <!-- Mobile: Container Pools -->
      <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl p-6 text-white">
        <h3 class="text-lg font-bold mb-2">Container Pools</h3>
        <p class="text-sm opacity-90">Premium pool solutions</p>
      </div>
      
      <!-- Mobile: Tiny Homes -->
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-6 text-white">
        <h3 class="text-lg font-bold mb-2">Tiny Homes</h3>
        <p class="text-sm opacity-90">Modern living</p>
      </div>
      
      <!-- Mobile: Storage Units -->
      <div class="bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl p-6 text-white">
        <h3 class="text-lg font-bold mb-2">Storage Units</h3>
        <p class="text-sm opacity-90">Secure solutions</p>
      </div>
      
      <!-- Mobile: Restroom Solutions -->
      <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl p-6 text-white">
        <h3 class="text-lg font-bold mb-2">Restroom Solutions</h3>
        <p class="text-sm opacity-90 mb-3">Portable and permanent restroom solutions</p>
        <div class="text-sm bg-white/20 inline-block px-3 py-1 rounded">
          Starting at $3,500
        </div>
      </div>
    </div>
  </div>
</section>
