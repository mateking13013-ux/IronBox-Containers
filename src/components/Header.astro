---
const menuItems = [
  { label: 'Home', href: '/' },
  { label: 'Shop All', href: '/shop' },
  {
    label: 'Containers',
    href: '/shop',
    children: [
      { label: '10ft Used Containers', href: '/categories/10-ft-used-shipping-containers' },
      { label: '10ft New Containers', href: '/categories/10ft-new-shipping-containers' },
      { label: '20ft Used Containers', href: '/categories/20ft-used-shipping-containers' },
      { label: '20ft New Containers', href: '/categories/20ft-new-shipping-containers' },
      { label: '40ft Used Containers', href: '/categories/40ft-used-shipping-containers' },
      { label: '40ft New Containers', href: '/categories/40ft-new-shipping-containers' },
      { label: 'High Cube Containers', href: '/categories/high-cube-shipping-containers' },
      { label: 'Refrigerated Containers', href: '/categories/refrigerated-shipping-containers' },
      { label: 'Flat Pack Containers', href: '/categories/flat-pack-shipping-containers' },
    ],
  },
  {
    label: 'More Products',
    href: '/shop',
    children: [
      { label: 'Guard Booths & Shacks', href: '/categories/guard-booths-shacks-houses' },
      { label: 'Modified Containers', href: '/categories/modified-containers' },
      { label: 'Portable Offices', href: '/categories/portable-site-office-containers' },
      { label: 'Plastic Drums & IBC', href: '/categories/plastic-drums-and-ibc-totes' },
      { label: 'Plastic Pallets', href: '/categories/plastic-pallets' },
    ],
  },
  { label: 'Guard Booths', href: '/categories/guard-booths-shacks-houses' },
  { label: 'Refrigerated', href: '/categories/refrigerated-shipping-containers' },
  { label: 'Offices', href: '/categories/portable-site-office-containers' },
  { label: 'About', href: '/about' },
  {
    label: 'Support',
    href: '/contact',
    children: [
      { label: 'Shipping & Delivery', href: '/shipping-policy' },
      { label: 'Returns & Warranty', href: '/return-policy' },
      { label: 'Terms of Service', href: '/terms-of-service' },
      { label: 'Privacy Policy', href: '/privacy-policy' },
      { label: 'Contact Us', href: '/contact' },
    ],
  },
];
---

<header class="fixed inset-x-0 top-0 z-50 bg-white shadow-sm">

  <!-- Top Row: Logo | Search | Contact | Cart & Shop -->
  <div class="border-b border-gray-100">
    <div class="mx-auto flex h-16 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:gap-6 lg:px-8">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Ironbox South Africa">
        <img src="/images/branding/ironbox-logo.png" alt="Ironbox South Africa" class="h-10 w-auto sm:h-11" />
      </a>

      <!-- Search Bar -->
      <div class="relative hidden flex-1 sm:block">
        <form action="/shop" method="get" class="relative">
          <input
            type="search"
            name="search"
            placeholder="Search containers, guard booths, offices..."
            class="w-full rounded-lg border border-gray-200 bg-gray-50 py-2 pl-10 pr-4 text-sm text-gray-700 transition placeholder:text-gray-400 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500"
          />
          <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" /></svg>
        </form>
      </div>

      <!-- Contact Info (desktop) -->
      <div class="hidden items-center gap-5 lg:flex">
        <a href="tel:+27123456789" class="flex items-center gap-2 text-sm text-gray-600 transition hover:text-gray-900">
          <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          <span class="font-medium">+27 12 345 6789</span>
        </a>
        <a href="mailto:sales@ironboxcontainers.com" class="flex items-center gap-2 text-sm text-gray-600 transition hover:text-gray-900">
          <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          <span class="font-medium">sales@ironboxcontainers.com</span>
        </a>
      </div>

      <!-- Cart -->
      <div class="relative group z-[100000]">
        <a href="/cart" class="relative flex items-center gap-1.5 rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 transition hover:border-gray-300 hover:bg-gray-50">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" /></svg>
          <span class="hidden sm:inline">Cart</span>
          <span id="cart-count" class="absolute -top-1.5 -right-1.5 hidden h-5 w-5 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white"></span>
        </a>

        <!-- Cart Dropdown -->
        <div id="cart-dropdown" class="invisible opacity-0 group-hover:visible group-hover:opacity-100 absolute right-0 top-full mt-2 w-80 rounded-xl border border-gray-200 bg-white shadow-2xl transition-all duration-200 z-[100000]">
          <div class="p-4">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-semibold text-gray-900">Shopping Cart</h3>
              <span id="cart-dropdown-count" class="text-xs text-gray-400">0 items</span>
            </div>
            <div id="cart-dropdown-items" class="max-h-64 overflow-y-auto space-y-3 mb-3">
              <p class="text-sm text-gray-400 text-center py-6">Your cart is empty</p>
            </div>
            <div class="border-t border-gray-100 pt-3 mb-3">
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-gray-600">Subtotal</span>
                <span id="cart-dropdown-total" class="text-sm font-bold text-gray-900">R0</span>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-2">
              <a href="/cart" class="rounded-lg bg-gray-900 px-4 py-2 text-center text-xs font-semibold text-white transition hover:bg-gray-800">View Cart</a>
              <a href="/checkout" class="rounded-lg bg-blue-600 px-4 py-2 text-center text-xs font-semibold text-white transition hover:bg-blue-700">Checkout</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Shop All Button (desktop) -->
      <a href="/shop" class="hidden items-center gap-2 rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-gray-800 lg:inline-flex">
        Shop All
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>

      <!-- Mobile: Search + Hamburger -->
      <button type="button" class="sm:hidden flex h-10 w-10 items-center justify-center rounded-lg text-gray-600" data-mobile-search-toggle>
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" /></svg>
      </button>
      <button type="button" class="flex h-10 w-10 items-center justify-center rounded-lg border border-gray-200 text-gray-600 transition hover:bg-gray-50 lg:hidden" data-mobile-toggle>
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5M3.75 12h16.5m-16.5 6.75h16.5" /></svg>
      </button>
    </div>
  </div>

  <!-- Bottom Row: Navigation Menu Bar -->
  <div class="hidden border-b border-gray-100 bg-gray-50 lg:block">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-1">
        {menuItems.map((item) => (
          item.children ? (
            <div class="group relative">
              <a href={item.href} class="flex items-center gap-1 px-4 py-3 text-[13px] font-medium text-gray-600 transition hover:text-gray-900">
                {item.label}
                <svg class="h-3.5 w-3.5 text-gray-400 transition group-hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" /></svg>
              </a>
              <div class="invisible absolute left-0 top-full z-30 w-64 rounded-xl border border-gray-200 bg-white p-2 opacity-0 shadow-xl transition-all duration-200 group-hover:visible group-hover:opacity-100">
                {item.children.map((child) => (
                  <a href={child.href} class="flex items-center justify-between rounded-lg px-3 py-2 text-[13px] text-gray-600 transition hover:bg-gray-50 hover:text-gray-900">
                    {child.label}
                    <svg class="h-3.5 w-3.5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" /></svg>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class="px-4 py-3 text-[13px] font-medium text-gray-600 transition hover:text-gray-900">
              {item.label}
            </a>
          )
        ))}
      </nav>
    </div>
  </div>

  <!-- Mobile Search Bar (toggled) -->
  <div class="hidden border-b border-gray-100 bg-white px-4 py-3 sm:hidden" data-mobile-search-bar>
    <form action="/shop" method="get" class="relative">
      <input type="search" name="search" placeholder="Search products..." class="w-full rounded-lg border border-gray-200 bg-gray-50 py-2 pl-10 pr-4 text-sm" />
      <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" /></svg>
    </form>
  </div>

  <!-- Mobile Slide-out Menu -->
  <div class="pointer-events-none fixed inset-0 z-[100002] hidden bg-black/60" data-mobile-backdrop>
    <div class="absolute right-0 top-0 h-full w-[85%] max-w-sm translate-x-full bg-white shadow-2xl transition-transform duration-200" data-mobile-panel>
      <div class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
        <img src="/images/branding/ironbox-logo.png" alt="Ironbox" class="h-8 w-auto" />
        <button type="button" class="flex h-9 w-9 items-center justify-center rounded-lg bg-gray-100 text-gray-600 transition hover:bg-gray-200" data-mobile-close>
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="overflow-y-auto px-5 pb-10 pt-4 space-y-2">
        {menuItems.map((item) => (
          <div>
            {item.children ? (
              <details class="group rounded-lg border border-gray-100">
                <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-medium text-gray-900">
                  {item.label}
                  <svg class="h-4 w-4 text-gray-400 transition group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" /></svg>
                </summary>
                <div class="space-y-0.5 px-4 pb-3">
                  {item.children.map((child) => (
                    <a href={child.href} class="block rounded-lg px-3 py-2 text-sm text-gray-600 transition hover:bg-gray-50 hover:text-gray-900" data-mobile-link>{child.label}</a>
                  ))}
                </div>
              </details>
            ) : (
              <a href={item.href} class="block rounded-lg px-4 py-3 text-sm font-medium text-gray-900 transition hover:bg-gray-50" data-mobile-link>
                {item.label}
              </a>
            )}
          </div>
        ))}

        <div class="border-t border-gray-100 pt-4 mt-4 space-y-3">
          <a href="tel:+27123456789" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-600">
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +27 12 345 6789
          </a>
          <a href="mailto:sales@ironboxcontainers.com" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-600">
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            sales@ironboxcontainers.com
          </a>
          <a href="/shop" class="block rounded-lg bg-gray-900 px-4 py-3 text-center text-sm font-semibold text-white" data-mobile-link>Shop All Products</a>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-[104px]"></div>

<script type="module">
  function formatPrice(price) {
    return 'R' + new Intl.NumberFormat('en-ZA', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(price);
  }

  const CART_KEY = 'ironbox_cart';

  function getStoredCart() {
    return JSON.parse(localStorage.getItem(CART_KEY) || localStorage.getItem('cart') || '[]');
  }

  function updateCartDropdown() {
    const cart = getStoredCart();
    const dropdownItems = document.getElementById('cart-dropdown-items');
    const dropdownCount = document.getElementById('cart-dropdown-count');
    const dropdownTotal = document.getElementById('cart-dropdown-total');

    if (!dropdownItems) return;

    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

    if (dropdownCount) dropdownCount.textContent = totalItems === 1 ? '1 item' : `${totalItems} items`;
    if (dropdownTotal) dropdownTotal.textContent = formatPrice(subtotal);

    if (cart.length === 0) {
      dropdownItems.innerHTML = '<p class="text-sm text-gray-400 text-center py-6">Your cart is empty</p>';
    } else {
      dropdownItems.innerHTML = cart.map(item => `
        <div class="flex items-start gap-3 pb-3 border-b border-gray-100 last:border-0">
          ${item.image
            ? `<img src="${item.image}" alt="${item.name}" class="w-14 h-14 object-cover rounded-lg flex-shrink-0">`
            : `<div class="w-14 h-14 bg-gray-100 rounded-lg flex-shrink-0"></div>`
          }
          <div class="flex-1 min-w-0">
            <h4 class="text-xs font-medium text-gray-900 mb-0.5 line-clamp-2">${item.name}</h4>
            <p class="text-[11px] text-gray-400">Qty: ${item.quantity}</p>
            <p class="text-xs font-bold text-gray-900 mt-0.5">${formatPrice(item.price * item.quantity)}</p>
          </div>
        </div>
      `).join('');
    }
  }

  function updateCartCount() {
    const cartCountEl = document.getElementById('cart-count');
    if (!cartCountEl) return;

    const cart = getStoredCart();
    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);

    if (totalItems > 0) {
      cartCountEl.textContent = totalItems > 99 ? '99+' : totalItems;
      cartCountEl.classList.remove('hidden');
      cartCountEl.classList.add('flex');
    } else {
      cartCountEl.classList.add('hidden');
      cartCountEl.classList.remove('flex');
    }
  }

  function updateCart() {
    updateCartCount();
    updateCartDropdown();
  }

  updateCart();
  window.addEventListener('storage', updateCart);
  window.addEventListener('cartUpdated', updateCart);

  // Mobile menu
  const backdrop = document.querySelector('[data-mobile-backdrop]');
  const panel = document.querySelector('[data-mobile-panel]');
  const toggle = document.querySelector('[data-mobile-toggle]');
  const closeBtn = document.querySelector('[data-mobile-close]');
  const mobileLinks = document.querySelectorAll('[data-mobile-link]');

  const openMobile = () => {
    if (!backdrop || !panel) return;
    backdrop.classList.remove('hidden');
    requestAnimationFrame(() => {
      backdrop.classList.remove('pointer-events-none');
      panel.classList.remove('translate-x-full');
    });
  };

  const closeMobile = () => {
    if (!backdrop || !panel) return;
    panel.classList.add('translate-x-full');
    backdrop.classList.add('pointer-events-none');
    setTimeout(() => backdrop.classList.add('hidden'), 200);
  };

  toggle?.addEventListener('click', openMobile);
  closeBtn?.addEventListener('click', closeMobile);
  backdrop?.addEventListener('click', (e) => { if (e.target === backdrop) closeMobile(); });
  mobileLinks.forEach((link) => link.addEventListener('click', closeMobile));

  // Mobile search toggle
  const mobileSearchToggle = document.querySelector('[data-mobile-search-toggle]');
  const mobileSearchBar = document.querySelector('[data-mobile-search-bar]');
  mobileSearchToggle?.addEventListener('click', () => {
    mobileSearchBar?.classList.toggle('hidden');
    const input = mobileSearchBar?.querySelector('input');
    if (input && !mobileSearchBar?.classList.contains('hidden')) input.focus();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMobile();
  });
</script>
