---
// Cart button component that shows the cart count
---

<a href="/cart" class="relative inline-flex items-center gap-1 rounded-[6px] bg-primary-foreground/10 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-primary-foreground transition hover:bg-primary-foreground/20">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
  </svg>
  Cart
  <span id="header-cart-count" class="absolute -top-1 -right-1 hidden h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[9px] font-bold text-white">0</span>
</a>

<script>
  import { cart } from '../lib/cart.js';

  // Update cart count on page load
  function updateCartCount() {
    const count = cart.getItemCount();
    const cartCountElement = document.getElementById('header-cart-count');

    if (cartCountElement) {
      if (count > 0) {
        cartCountElement.textContent = count.toString();
        cartCountElement.style.display = 'flex';
      } else {
        cartCountElement.style.display = 'none';
      }
    }
  }

  // Update on load
  updateCartCount();

  // Listen for cart updates
  window.addEventListener('cartUpdated', updateCartCount);
</script>
