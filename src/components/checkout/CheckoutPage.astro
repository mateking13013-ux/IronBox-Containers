---
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Cart', href: '/cart' },
  { label: 'Checkout', href: '/checkout' },
];

const steps = [
  { number: 1, name: 'Shipping', status: 'complete' },
  { number: 2, name: 'Payment', status: 'complete' },
  { number: 3, name: 'Review', status: 'current' },
];

const addresses = [
  {
    id: 0,
    name: 'Alex Morgan',
    street: '1421 Horizon Parkway',
    city: 'Austin',
    state: 'TX',
    zip: '73301',
    country: 'South Africa',
    phone: '+1 (737) 555-8020',
    isDefault: true,
  },
  {
    id: 1,
    name: 'Alex Morgan',
    street: '305 Yard Street Suite 4B',
    city: 'Johannesburg',
    state: 'GP',
    zip: '75201',
    country: 'South Africa',
    phone: '+1 (214) 555-4412',
    isDefault: false,
  },
];

const shippingOptions = [
  {
    id: 'standard',
    name: 'Standard Installation Window',
    description: '6-8 week nationwide delivery. Scheduling coordinated with local crane partner.',
    estimated: 'Arrives August 12-20',
    cost: 0,
    badge: 'Included',
  },
  {
    id: 'priority',
    name: 'Priority Crane & Crew',
    description: 'Expedited crane placement with Saturday availability.',
    estimated: 'Arrives July 28-August 1',
    cost: 1850,
    badge: 'Popular',
  },
  {
    id: 'site-pickup',
    name: 'Yard Pickup',
    description: 'Pick up at our fabrication yard. Includes load-out assistance.',
    estimated: 'Ready July 18',
    cost: 0,
    badge: 'DIY',
  },
];

const paymentMethods = [
  {
    id: 'ach',
    name: 'ACH or Wire Transfer',
    description: 'Secure bank transfer with 3-day confirmation. Recommended for installations.',
    detail: 'Routing and account details provided after order submission.',
    badge: 'Best Value',
    selected: true,
  },
  {
    id: 'card',
    name: 'Credit Card (3% processing)',
    description: 'Visa, Mastercard, and accepted up to R450,000.',
    detail: 'Processing fee applied to balance due at shipment.',
    selected: false,
  },
  {
    id: 'financing',
    name: 'Builder Financing',
    description: 'Partnered lending with flexible 5-20 year terms.',
    detail: 'Pre-approval required prior to installation scheduling.',
    selected: false,
  },
];

const orderItems = [
  { name: 'Signature Container Pool 30FT', quantity: 1, price: 24500 },
  { name: 'Executive Restroom Suite', quantity: 1, price: 21900 },
];

const subtotal = orderItems.reduce((total, item) => total + item.price * item.quantity, 0);
const savings = 3900;
const depositDue = 2000;
const shippingCost = shippingOptions[0].cost;
const estimatedTotal = subtotal + shippingCost;

const supportNotes = [
  {
    title: 'Permit Support',
    description: 'Stamped drawings included. We coordinate with your local plan reviewer.',
  },
  {
    title: 'Site Preparation',
    description: 'We review pad prep, electrical, and gas stubs before delivery.',
  },
  {
    title: 'Concierge Team',
    description: 'Dedicated project manager assigned once your order is submitted.',
  },
];

const reassurance = [
  {
    icon: 'shield',
    title: 'Secure checkout',
    description: '256-bit SSL encryption protects your project details and payment info.',
  },
  {
    icon: 'truck',
    title: 'Nationwide install',
    description: 'Licensed and insured set crews in all 9 provinces with white-glove delivery.',
  },
  {
    icon: 'calendar',
    title: 'Flexible scheduling',
    description: 'Coordinate delivery around permit approvals and utility readiness.',
  },
];

const formatCurrency = (value: number) =>
  'R' + value.toLocaleString('en-ZA', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
---

<section class="bg-background text-foreground">
  <div class="border-b border-border bg-muted/20">
    <div class="mx-auto max-w-6xl px-4 py-6">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        {breadcrumbs.map((crumb, index) => (
          <div class="flex items-center">
            {index > 0 && <span class="px-1 text-muted-foreground">/</span>}
            {index === breadcrumbs.length - 1 ? (
              <span class="font-semibold text-foreground">{crumb.label}</span>
            ) : (
              <a href={crumb.href} class="transition hover:text-foreground">{crumb.label}</a>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-semibold">Checkout</h1>
      <p class="mt-2 text-sm text-muted-foreground">Finalize delivery details, confirm installation windows, and secure your project.</p>

      <div class="mt-8 flex flex-wrap items-center gap-6">
        {steps.map((step, index) => (
          <div class="flex items-center gap-4">
            <div class={`flex h-12 w-12 items-center justify-center rounded-full text-sm font-semibold ${
              step.status === 'complete'
                ? 'bg-primary text-primary-foreground'
                : step.status === 'current'
                ? 'border-2 border-primary text-primary'
                : 'bg-muted text-muted-foreground'
            }`}>
              {step.status === 'complete' ? (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              ) : (
                step.number
              )}
            </div>
            <div>
              <p class={`font-semibold ${step.status !== 'incomplete' ? 'text-foreground' : 'text-muted-foreground'}`}>{step.name}</p>
              <p class="text-xs text-muted-foreground">{step.status === 'current' ? 'Review & submit' : step.status === 'complete' ? 'Confirmed' : 'Pending'}</p>
            </div>
            {index < steps.length - 1 && <div class="hidden h-px w-16 bg-border sm:block" />}
          </div>
        ))}
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
      <div class="space-y-8">
        <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
          <h2 class="text-lg font-semibold">Checkout preference</h2>
          <div class="mt-4 space-y-4">
            <div class="rounded-xl border border-primary bg-primary/5 p-4">
              <div class="flex items-start gap-3">
                <span class="mt-1 flex h-4 w-4 items-center justify-center rounded-full border border-primary bg-primary text-[10px] text-primary-foreground">✓</span>
                <div class="space-y-2">
                  <div class="flex items-center gap-2">
                    <p class="font-semibold">Checkout as guest</p>
                    <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">Fastest</span>
                  </div>
                  <p class="text-sm text-muted-foreground">Receive project updates and scheduling information at <span class="font-medium text-foreground">projects@ironboxcontainers.com</span>.</p>
                  <div class="grid gap-3 md:grid-cols-[2fr_3fr]">
                    <input type="email" value="projects@ironboxcontainers.com" class="rounded-lg border border-border bg-background px-3 py-2 text-sm" />
                    <p class="text-xs text-muted-foreground">We’ll send you the install checklist, crane requirements, and payment milestones.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="rounded-xl border border-border p-4">
              <div class="flex items-start gap-3">
                <span class="mt-1 flex h-4 w-4 items-center justify-center rounded-full border border-border text-[10px] text-muted-foreground">•</span>
                <div class="space-y-2">
                  <p class="font-semibold">Sign in for saved addresses</p>
                  <p class="text-sm text-muted-foreground">Access your saved job sites, payment preferences, and previous installations.</p>
                  <a href="/auth/login" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">Sign in to continue <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg></a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Shipping address</h2>
            <a href="#" class="text-sm font-semibold text-primary hover:underline">Edit</a>
          </div>
          <div class="space-y-4">
            {addresses.map((address) => (
              <div class={`rounded-xl border p-4 ${address.isDefault ? 'border-primary bg-primary/5' : 'border-border'}`}>
                <div class="flex items-start gap-3">
                  <span class={`mt-1 flex h-4 w-4 items-center justify-center rounded-full text-[10px] ${address.isDefault ? 'bg-primary text-primary-foreground' : 'border border-border text-muted-foreground'}`}>{address.isDefault ? '✓' : '•'}</span>
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <p class="font-semibold">{address.name}</p>
                      {address.isDefault && <span class="rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-primary">Primary</span>}
                    </div>
                    <p class="mt-1 text-sm text-muted-foreground">
                      {address.street}<br />
                      {address.city}, {address.state} {address.zip}<br />
                      {address.country}<br />
                      {address.phone}
                    </p>
                  </div>
                </div>
              </div>
            ))}

            <div class="rounded-xl border border-dashed border-border p-4 text-center text-sm text-primary">
              <span class="inline-flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" /></svg>Add a new site address</span>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Installation scheduling</h2>
            <span class="text-xs font-semibold uppercase tracking-wide text-primary">Step 2</span>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            {shippingOptions.map((option) => (
              <div class={`rounded-xl border p-4 ${option.id === 'standard' ? 'border-primary bg-primary/5' : 'border-border'}`}>
                <div class="flex items-center justify-between">
                  <p class="font-semibold">{option.name}</p>
                  <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">{option.badge}</span>
                </div>
                <p class="mt-2 text-sm text-muted-foreground">{option.description}</p>
                <p class="mt-3 text-sm font-semibold text-foreground">{option.cost === 0 ? 'Included' : formatCurrency(option.cost)}</p>
                <p class="text-xs text-green-600">{option.estimated}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Payment method</h2>
            <p class="text-xs text-muted-foreground">Balance due before delivery</p>
          </div>
          <div class="space-y-4">
            {paymentMethods.map((method) => (
              <div class={`rounded-xl border p-4 ${method.selected ? 'border-primary bg-primary/5' : 'border-border'}`}>
                <div class="flex items-start gap-3">
                  <span class={`mt-1 flex h-4 w-4 items-center justify-center rounded-full text-[10px] ${method.selected ? 'bg-primary text-primary-foreground' : 'border border-border text-muted-foreground'}`}>{method.selected ? '✓' : '•'}</span>
                  <div class="space-y-2">
                    <div class="flex items-center gap-2">
                      <p class="font-semibold">{method.name}</p>
                      {method.badge && <span class="rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-primary">{method.badge}</span>}
                    </div>
                    <p class="text-sm text-muted-foreground">{method.description}</p>
                    <p class="text-xs text-muted-foreground">{method.detail}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
          <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Review & submit</h2>
            <span class="text-xs font-semibold uppercase tracking-wide text-primary">Step 3</span>
          </div>
          <div class="space-y-5 text-sm">
            <div>
              <p class="font-semibold text-foreground">Project items</p>
              <div class="mt-3 space-y-2">
                {orderItems.map((item) => (
                  <div class="flex items-center justify-between text-muted-foreground">
                    <span>{item.name} × {item.quantity}</span>
                    <span class="font-medium text-foreground">{formatCurrency(item.price * item.quantity)}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="rounded-xl border border-border bg-muted/30 p-4 text-xs text-muted-foreground">
              By submitting your order you agree to the IronBox Containers Terms of Service and acknowledge the site-readiness checklist. A project concierge will contact you within one business day.
            </div>

            <a href="/checkout/thank-you" class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
              Submit order & secure schedule
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg>
            </a>
          </div>
        </div>

        <div class="grid gap-4 rounded-2xl border border-border bg-muted/30 p-6 md:grid-cols-3">
          {supportNotes.map((item) => (
            <div class="space-y-2">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">{item.title}</h3>
              <p class="text-sm text-muted-foreground">{item.description}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="space-y-6">
        <div class="rounded-2xl border border-border bg-muted/30 p-5 text-sm text-muted-foreground">
          Already a client? <a href="/auth/login" class="font-semibold text-primary hover:underline">Sign in to apply saved financing</a>
        </div>

        <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
          <h2 class="text-lg font-semibold">Order summary</h2>
          <div class="mt-4 space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-muted-foreground">Subtotal</span>
              <span class="font-medium text-foreground">{formatCurrency(subtotal)}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted-foreground">Package savings</span>
              <span class="text-green-600">- {formatCurrency(savings)}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted-foreground">Delivery & install</span>
              <span class={shippingCost === 0 ? 'text-green-600' : 'font-medium text-foreground'}>{shippingCost === 0 ? 'Included' : formatCurrency(shippingCost)}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted-foreground">Deposit due today</span>
              <span class="font-medium text-foreground">{formatCurrency(depositDue)}</span>
            </div>
          </div>

          <div class="mt-6 rounded-xl border border-dashed border-border p-4 text-sm">
            <p class="font-semibold text-foreground">Financing or promo code</p>
            <div class="mt-3 flex gap-2">
              <input type="text" placeholder="Enter code" class="flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm" />
              <button class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90">Apply</button>
            </div>
          </div>

          <div class="mt-6 flex items-center justify-between">
            <span class="text-base font-semibold">Estimated total</span>
            <span class="text-2xl font-bold text-foreground">{formatCurrency(estimatedTotal)}</span>
          </div>
          <p class="mt-2 text-xs text-muted-foreground">Final invoice issued 10 days prior to delivery once crane logistics and permits are confirmed.</p>

          <a href="/checkout/thank-you" class="mt-6 block rounded-full border border-border px-6 py-3 text-center text-sm font-semibold text-foreground transition hover:bg-muted">Pay deposit & continue</a>

          <div class="mt-6 space-y-3 text-xs text-muted-foreground">
            <p class="font-semibold text-foreground">Accepted methods</p>
            <div class="flex flex-wrap gap-2">
              {['ACH', 'Wire', 'VISA', 'AmEx', 'Mastercard'].map((method) => (
                <span class="inline-flex h-8 items-center justify-center rounded-md border border-border bg-muted/40 px-3 text-xs font-semibold">{method}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-4 rounded-2xl border border-border bg-muted/20 p-6 text-sm">
          {reassurance.map((item) => (
            <div class="flex items-start gap-3">
              <div class="mt-1 rounded-full bg-primary/10 p-2 text-primary">
                {item.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75c1.148-.849 2.667-1.5 4.5-1.5 1.833 0 3.352.651 4.5 1.5v4.5c0 4.5-3 8.25-9 11-6-2.75-9-6.5-9-11v-4.5c1.148-.849 2.667-1.5 4.5-1.5 1.833 0 3.352.651 4.5 1.5z" /></svg>}
                {item.icon === 'truck' && <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6h11v11H3zM14 8h4l3 4v5h-7" /></svg>}
                {item.icon === 'calendar' && <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
              </div>
              <div>
                <p class="font-semibold text-foreground uppercase tracking-wide text-xs">{item.title}</p>
                <p class="text-sm text-muted-foreground">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>
