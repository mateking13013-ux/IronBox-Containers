---
const order = {
  number: 'NT-20437',
  placedOn: 'July 8, 2024',
  paymentStatus: 'Deposit received',
  fulfillmentStatus: 'Scheduling concierge assigned',
  subtotal: 46400,
  shipping: 0,
  tax: 0,
  total: 46400,
  depositCollected: 2000,
  balanceDue: 44400,
};

const items = [
  {
    name: 'Signature Container Pool 30FT',
    quantity: 1,
    price: 24500,
    image: 'https://images.unsplash.com/photo-1616628188410-5fe5b3ba1f80?auto=format&fit=crop&w=600&q=80',
  },
  {
    name: 'Executive Restroom Suite',
    quantity: 1,
    price: 21900,
    image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=600&q=80',
  },
];

const nextSteps = [
  {
    title: 'Site readiness review',
    description: 'Upload pad photos, utility stubs, and access notes so we can finalize crane logistics.',
    icon: 'clip',
  },
  {
    title: 'Permit concierge call',
    description: 'Your project manager will reach out within 1 business day to align on permit milestones.',
    icon: 'phone',
  },
  {
    title: 'Schedule installation window',
    description: 'Once permits are approved we will lock in a delivery week and assign your install crew.',
    icon: 'calendar',
  },
];

const resources = [
  { label: 'Shipping policy', href: '/shipping-policy' },
  { label: 'Return policy', href: '/return-policy' },
  { label: 'Contact support', href: '/contact' },
];

const formatCurrency = (value: number) =>
  'R' + value.toLocaleString('en-ZA', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
---

<section class="bg-background text-foreground">
  <div class="mx-auto max-w-3xl px-4 pb-16 pt-24">
    <div class="rounded-3xl border border-border bg-card p-8 shadow-lg">
      <div class="flex items-start gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold uppercase tracking-wide text-green-600">Order received</p>
          <h1 class="mt-2 text-2xl font-semibold text-foreground">Thank you for building with IronBox Containers</h1>
          <p class="mt-2 text-sm text-muted-foreground">We’ve emailed a detailed receipt and install checklist. Your concierge will connect shortly to coordinate permits and delivery.</p>
        </div>
      </div>

      <div class="mt-6 grid gap-6 rounded-2xl border border-border bg-muted/20 p-6 md:grid-cols-2">
        <div>
          <p class="text-xs uppercase tracking-wide text-muted-foreground">Order number</p>
          <p class="mt-1 font-mono text-lg font-semibold">{order.number}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wide text-muted-foreground">Order placed</p>
          <p class="mt-1 text-sm font-medium text-foreground">{order.placedOn}</p>
          <p class="text-xs text-muted-foreground">Payment status: <span class="font-semibold text-green-600">{order.paymentStatus}</span></p>
        </div>
      </div>

      <div class="mt-8 space-y-6">
        <div>
          <h2 class="text-lg font-semibold">Project items</h2>
          <div class="mt-4 space-y-4">
            {items.map((item) => (
              <div class="flex items-center gap-4 rounded-xl border border-border bg-background p-3">
                <div class="h-16 w-16 overflow-hidden rounded-lg bg-muted">
                  <img src={item.image} alt={item.name} class="h-full w-full object-cover" />
                </div>
                <div class="flex-1">
                  <p class="text-sm font-semibold text-foreground">{item.name}</p>
                  <p class="text-xs text-muted-foreground">Quantity: {item.quantity}</p>
                </div>
                <p class="text-sm font-semibold text-foreground">{formatCurrency(item.price)}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="grid gap-4 rounded-2xl border border-border bg-muted/30 p-6 md:grid-cols-2">
          <div class="space-y-2 text-sm">
            <div class="flex justify-between text-muted-foreground">
              <span>Subtotal</span>
              <span class="font-medium text-foreground">{formatCurrency(order.subtotal)}</span>
            </div>
            <div class="flex justify-between text-muted-foreground">
              <span>Shipping</span>
              <span class="font-medium text-green-600">{order.shipping === 0 ? 'Included' : formatCurrency(order.shipping)}</span>
            </div>
            <div class="flex justify-between text-muted-foreground">
              <span>Tax</span>
              <span class="font-medium text-foreground">{formatCurrency(order.tax)}</span>
            </div>
          </div>
          <div class="rounded-xl border border-border bg-background p-4 text-sm">
            <div class="flex justify-between text-muted-foreground">
              <span>Total project value</span>
              <span class="text-lg font-bold text-foreground">{formatCurrency(order.total)}</span>
            </div>
            <div class="mt-3 flex justify-between text-muted-foreground">
              <span>Deposit collected today</span>
              <span class="font-semibold text-green-600">{formatCurrency(order.depositCollected)}</span>
            </div>
            <div class="mt-1 flex justify-between text-muted-foreground">
              <span>Balance due before delivery</span>
              <span class="font-semibold text-foreground">{formatCurrency(order.balanceDue)}</span>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-lg font-semibold">What happens next</h2>
          <div class="mt-4 space-y-4">
            {nextSteps.map((step, index) => (
              <div class="flex gap-4 rounded-xl border border-border bg-background p-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
                  {step.icon === 'clip' && <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                  {step.icon === 'phone' && <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75C2.25 5.784 3.034 5 4 5h2.25c.85 0 1.566.616 1.715 1.454l.381 2.09a1.725 1.725 0 01-.436 1.483l-1.1 1.1a16.5 16.5 0 007.542 7.542l1.1-1.1c.39-.39.956-.566 1.483-.436l2.09.381A1.725 1.725 0 0119 17.75V20c0 .966-.784 1.75-1.75 1.75H17c-8.837 0-16-7.163-16-16V6.75z" /></svg>}
                  {step.icon === 'calendar' && <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
                </div>
                <div>
                  <p class="text-sm font-semibold text-foreground">{index + 1}. {step.title}</p>
                  <p class="mt-1 text-sm text-muted-foreground">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl border border-border bg-muted/20 p-5 text-sm">
          <p class="font-semibold text-foreground">Helpful resources</p>
          <p class="mt-2 text-sm text-muted-foreground">Need to review timelines or policies? These links cover freight, set crews, and customer care.</p>
          <div class="mt-4 flex flex-wrap gap-3">
            {resources.map((link) => (
              <a href={link.href} class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm font-semibold text-primary hover:bg-primary/10">
                {link.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg>
              </a>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-3 border-t border-border pt-6 text-sm">
          <a href="/shop" class="text-primary hover:underline">Continue browsing products</a>
          <a href="/account/orders" class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
            View order history
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
