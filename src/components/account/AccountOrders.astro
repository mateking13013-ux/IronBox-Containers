---
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Account', href: '/account' },
  { label: 'Orders', href: '/account/orders' },
];

const orders = [
  {
    number: 'NT-20437',
    date: 'June 24, 2024',
    total: 46400,
    status: 'In scheduling',
    items: [
      {
        name: 'Signature Container Pool 30FT',
        quantity: 1,
        price: 24500,
        image: 'https://images.unsplash.com/photo-1616628188410-5fe5b3ba1f80?auto=format&fit=crop&w=300&q=80',
      },
      {
        name: 'Executive Restroom Suite',
        quantity: 1,
        price: 21900,
        image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=300&q=80',
      },
    ],
  },
  {
    number: 'NT-19892',
    date: 'March 3, 2024',
    total: 18900,
    status: 'Delivered',
    items: [
      {
        name: 'Secure Storage Plus',
        quantity: 2,
        price: 9450,
        image: 'https://images.unsplash.com/photo-1503389152951-9f343605f61e?auto=format&fit=crop&w=300&q=80',
      },
    ],
  },
];

const statusBadge = (status: string) => {
  switch (status) {
    case 'Delivered':
      return 'text-green-600 bg-green-100';
    case 'In scheduling':
      return 'text-orange-600 bg-orange-100';
    default:
      return 'text-muted-foreground bg-muted';
  }
};

const formatCurrency = (value: number) =>
  'R' + value.toLocaleString('en-ZA', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
---

<section class="bg-background text-foreground">
  <div class="border-b border-border bg-muted/20">
    <div class="mx-auto max-w-5xl px-4 py-6">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        {breadcrumbs.map((crumb, index) => (
          <div class="flex items-center">
            {index > 0 && <span class="px-1">/</span>}
            {index === breadcrumbs.length - 1 ? (
              <span class="font-semibold text-foreground">{crumb.label}</span>
            ) : (
              <a href={crumb.href} class="transition hover:text-foreground">{crumb.label}</a>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>

  <div class="mx-auto max-w-5xl px-4 py-12 space-y-8">
    <div>
      <a href="/account" class="text-xs font-semibold uppercase tracking-wide text-primary hover:underline">← Back to account</a>
      <h1 class="mt-3 text-3xl font-semibold">My orders</h1>
      <p class="mt-2 text-sm text-muted-foreground">Track fabrication progress, craning windows, and payment status for each project.</p>
    </div>

    {orders.length === 0 ? (
      <div class="rounded-2xl border border-border bg-card p-10 text-center shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20.25h6m-7.5-3h9m1.5-9.75h-12l-.75 9.75h13.5l-.75-9.75zM9 6.75V3.75h6v3" /></svg>
        <h2 class="mt-4 text-lg font-semibold text-foreground">No orders yet</h2>
        <p class="mt-2 text-sm text-muted-foreground">When you place your first order you&rsquo;ll be able to monitor delivery and install milestones here.</p>
        <a href="/shop" class="mt-6 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">Browse products <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg></a>
      </div>
    ) : (
      <div class="space-y-6">
        {orders.map((order) => (
          <article class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm">
            <header class="border-b border-border bg-muted/30 p-6">
              <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <p class="text-sm text-muted-foreground">Order number</p>
                  <p class="text-lg font-semibold text-foreground">{order.number}</p>
                </div>
                <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                  <span class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Placed {order.date}
                  </span>
                  <span class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5v9a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 16.5v-9A1.5 1.5 0 014.5 6h15A1.5 1.5 0 0121 7.5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M3 9h18" /></svg>
                    {formatCurrency(order.total)}
                  </span>
                  <span class={`inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold ${statusBadge(order.status)}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12c0 5.385 4.365 9.75 9.75 9.75s9.75-4.365 9.75-9.75S17.385 2.25 12 2.25 2.25 6.615 2.25 12zm10.5-6.75v6.75l3.75 1.875" /></svg>
                    {order.status}
                  </span>
                </div>
              </div>
            </header>

            <div class="space-y-4 p-6">
              {order.items.map((item) => (
                <div class="flex flex-col gap-4 rounded-xl border border-border bg-background p-4 md:flex-row md:items-center">
                  <div class="h-20 w-full overflow-hidden rounded-lg bg-muted md:w-20">
                    <img src={item.image} alt={item.name} class="h-full w-full object-cover" />
                  </div>
                  <div class="flex-1">
                    <p class="text-sm font-semibold text-foreground">{item.name}</p>
                    <p class="text-xs text-muted-foreground">Quantity: {item.quantity}</p>
                  </div>
                  <div class="text-right text-sm font-semibold text-foreground">{formatCurrency(item.price * item.quantity)}</div>
                </div>
              ))}
              <div class="flex flex-wrap items-center justify-between gap-3 border-t border-border pt-4 text-sm">
                <span class="text-muted-foreground">Need delivery updates? Email info@ironboxcontainers.co.za</span>
                <a href="#" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">View delivery schedule <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5l9 7.5-9 7.5" /></svg></a>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
