---
interface Props {
  locationName: string;
  phoneNumber: string;
}

const { locationName, phoneNumber } = Astro.props;
---

<!-- CTA Section -->
<section class="bg-blue-600 text-white py-16 px-6">
  <div class="max-w-4xl mx-auto text-center space-y-6">
    <h2 class="text-3xl font-bold">Need a Shipping Container in {locationName} Today?</h2>
    <p class="text-lg opacity-90">
      Don't wait! Call us now for immediate assistance and same-day quotes.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:{phoneNumber}" class="inline-flex items-center justify-center px-8 py-4 bg-white text-blue-600 text-lg font-medium rounded-lg hover:bg-gray-100 transition-colors">
        <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        Call {phoneNumber}
      </a>
      <button class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white text-lg font-medium rounded-lg hover:bg-white hover:text-blue-600 transition-colors">
        <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        Email Us
      </button>
    </div>
  </div>
</section>
