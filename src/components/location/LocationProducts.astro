---
interface Product {
  product_name: string;
  product_description: string;
  product_price: string;
  product_features: Array<string>;
}

interface Props {
  products: Product[];
  locationName: string;
}

const { products, locationName } = Astro.props;
---

<!-- Products Section -->
<section class="py-20 px-6 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <div class="space-y-6 mb-12">
      <h2 class="text-3xl font-bold text-gray-900">Shipping Containers for Sale in {locationName}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Choose from our wide selection of high-quality containers perfect for storage, shipping, or custom projects. 
        Each container is thoroughly inspected and certified to meet industry standards.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {products.map((product, index) => (
        <div key={index} class="bg-white rounded-lg shadow-lg overflow-hidden flex flex-col">
          <div class="aspect-video bg-gray-200 flex items-center justify-center">
            <svg class="h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
          </div>
          <div class="p-6 flex-1 flex flex-col">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">{product.product_name}</h3>
            <p class="text-gray-600 mb-4">{product.product_description}</p>
            <div class="text-2xl font-bold text-orange-600 mb-6">{product.product_price}</div>
            <div class="mb-6 flex-1">
              <h4 class="font-semibold text-gray-900 mb-3">Key Features:</h4>
              <ul class="space-y-2">
                {product.product_features.map((feature, featureIndex) => (
                  <li key={featureIndex} class="flex items-center gap-2 text-gray-700">
                    <svg class="h-4 w-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            <button class="w-full bg-orange-500 text-white py-3 px-4 rounded-lg hover:bg-orange-600 transition-colors font-medium">
              Inquire About This Container
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
