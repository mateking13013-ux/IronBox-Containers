---
interface FAQItem {
  faq_question: string;
  faq_answer: string;
}

interface Props {
  faqItems: FAQItem[];
  locationName: string;
}

const { faqItems, locationName } = Astro.props;
---

<!-- FAQ Section -->
<section class="py-20 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
      <div class="bg-gray-50 px-6 py-8 border-b">
        <h2 class="text-2xl font-bold text-gray-900">Frequently Asked Questions</h2>
        <p class="text-gray-600 mt-2">
          Common questions about buying shipping containers in {locationName}
        </p>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          {faqItems.map((faq, index) => (
            <details key={index} class="group">
              <summary class="flex justify-between items-center cursor-pointer p-4 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors">
                <span class="font-medium text-gray-900 pr-4">{faq.faq_question}</span>
                <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div class="mt-2 px-4 pb-4 text-gray-600">
                <div set:html={faq.faq_answer} />
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
