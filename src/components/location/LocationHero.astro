---
interface Props {
  headline: string;
  subheadline: string;
  primaryCTAText: string;
  secondaryCTAText: string;
  serviceAreaText: string;
  locationName: string;
}

const { 
  headline, 
  subheadline, 
  primaryCTAText, 
  secondaryCTAText, 
  serviceAreaText, 
  locationName 
} = Astro.props;
---

<!-- Hero Section -->
<section class="relative bg-gradient-to-r from-blue-50 to-indigo-50 py-20 px-6">
  <div class="max-w-6xl mx-auto text-center space-y-6">
    <div class="inline-flex items-center px-4 py-2 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">
      {serviceAreaText || `Serving ${locationName} and Surrounding Areas`}
    </div>
    
    <h1 class="text-4xl lg:text-6xl font-bold tracking-tight text-gray-900">
      {headline}
    </h1>
    
    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      {subheadline}
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:555-0123" class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white text-lg font-medium rounded-lg hover:bg-blue-700 transition-colors">
        {primaryCTAText || 'Get Instant Quote'}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      
      <button class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-300 text-gray-700 text-lg font-medium rounded-lg hover:bg-gray-50 transition-colors">
        {secondaryCTAText || 'Browse Inventory'}
      </button>
    </div>
  </div>
</section>
