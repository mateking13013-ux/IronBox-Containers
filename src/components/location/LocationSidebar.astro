---
interface Props {
  locationName: string;
  phoneNumber: string;
  emailAddress: string;
  businessHours: string;
  locations: string[];
}

const { locationName, phoneNumber, emailAddress, businessHours, locations = [] } = Astro.props;
---

<!-- Sidebar Component -->
<div class="w-full lg:w-[30%] space-y-8">
  {/* Location Selector */}
  <div class="bg-white rounded-lg shadow-lg p-6">
    <h3 class="text-lg font-semibold text-gray-900 mb-2">Select Your Location</h3>
    <p class="text-gray-600 mb-4">Get local pricing and availability</p>
    <select class="w-full p-3 border border-gray-300 rounded-lg mb-4 focus:ring-2 focus:ring-orange-500 focus:border-orange-500">
      <option value="">Choose location</option>
      {locations.map((location) => (
        <option value={location}>{location}</option>
      ))}
    </select>
    <button class="w-full bg-orange-500 text-white py-3 px-4 rounded-lg hover:bg-orange-600 transition-colors font-medium">
      View Local Pricing
    </button>
  </div>

  {/* Contact Info */}
  <div class="bg-white rounded-lg shadow-lg p-6">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Contact Info</h3>
    <div class="space-y-3">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <span class="text-gray-700">{phoneNumber}</span>
      </div>
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <span class="text-gray-700">{emailAddress}</span>
      </div>
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-gray-700">{businessHours}</span>
      </div>
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span class="text-gray-700">Serving {locationName}</span>
      </div>
    </div>
  </div>

  {/* Popular Products */}
  <div class="bg-white rounded-lg shadow-lg p-6">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Popular in {locationName}</h3>
    <div class="space-y-3">
      <div class="border border-gray-200 rounded-lg p-3">
        <h4 class="font-semibold text-gray-900 mb-2">20ft Standard Container</h4>
        <p class="text-sm text-gray-600 mb-2">Perfect for storage and small shipping needs</p>
        <div class="flex items-center justify-between">
          <span class="font-bold text-orange-600">R45,000</span>
          <button class="text-orange-600 hover:text-orange-700 text-sm font-medium">
            Details →
          </button>
        </div>
      </div>
      <div class="border border-gray-200 rounded-lg p-3">
        <h4 class="font-semibold text-gray-900 mb-2">40ft Standard Container</h4>
        <p class="text-sm text-gray-600 mb-2">Ideal for large storage and commercial use</p>
        <div class="flex items-center justify-between">
          <span class="font-bold text-orange-600">R68,000</span>
          <button class="text-orange-600 hover:text-orange-700 text-sm font-medium">
            Details →
          </button>
        </div>
      </div>
    </div>
  </div>

  {/* Final CTA */}
  <div class="bg-orange-500 text-white rounded-lg shadow-lg p-6">
    <h3 class="text-lg font-semibold mb-3">Need Help?</h3>
    <p class="text-sm opacity-90 mb-4">
      Our {locationName} experts are ready to help you find the perfect container solution.
    </p>
    <a href="tel:{phoneNumber}" class="w-full inline-block bg-white text-orange-600 text-center py-3 px-4 rounded-lg hover:bg-gray-100 transition-colors font-medium">
      Call Now
    </a>
  </div>
</div>
