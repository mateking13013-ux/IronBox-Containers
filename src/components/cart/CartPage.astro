---
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Shop', href: '/shop' },
  { label: 'Cart', href: '/cart' },
];

const cartItems = [
  {
    id: 'pool-30ft',
    name: 'Signature Container Pool 30FT',
    slug: '/products/signature-container-pool-30ft',
    image: 'https://images.unsplash.com/photo-1616628188410-5fe5b3ba1f80?auto=format&fit=crop&w=640&q=80',
    color: 'Slate Black',
    size: '30FT',
    quantity: 1,
    price: 24500,
    originalPrice: 28900,
    deliveryDate: 'Tue, July 16',
    shipping: 'White-glove delivery included • Crane set in 1 day',
    protection: {
      available: true,
      plans: [
        { years: 3, price: 1495 },
        { years: 5, price: 2195 },
      ],
    },
  },
  {
    id: 'executive-restroom-suite',
    name: 'Executive Restroom Suite',
    slug: '/products/executive-restroom-suite',
    image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=640&q=80',
    color: 'Pearl White',
    size: '24FT',
    quantity: 1,
    price: 21900,
    originalPrice: 23500,
    deliveryDate: 'Fri, July 19',
    shipping: 'Expedited delivery window available',
    protection: {
      available: true,
      plans: [
        { years: 2, price: 695 },
        { years: 4, price: 1195 },
      ],
    },
  },
];

const subtotal = cartItems.reduce((acc, item) => acc + item.price * item.quantity, 0);
const savings = cartItems.reduce((acc, item) => {
  if (!item.originalPrice) return acc;
  return acc + (item.originalPrice - item.price) * item.quantity;
}, 0);

const shippingOptions = [
  {
    id: 'standard',
    name: 'Standard delivery',
    description: '6-8 week nationwide delivery window',
    cost: 0,
    estimated: 'Arrives mid-August',
    badge: 'Included',
  },
  {
    id: 'expedited',
    name: 'Expedited install crew',
    description: 'Priority crane scheduling with weekend availability',
    cost: 1850,
    estimated: 'Arrives late July',
    badge: 'Popular',
  },
];

const selectedShipping = shippingOptions[0];
const shippingCost = selectedShipping.cost;
const estimatedTotal = subtotal + shippingCost;

const acceptedMethods = ['ACH', 'Wire', 'VISA', 'AmEx'];

const reassurance = [
  { icon: 'shield', title: 'Secure Checkout', description: '256-bit SSL encryption keeps your project protected.' },
  { icon: 'check', title: 'Permit Support', description: 'Engineered drawings and site plan assistance included.' },
  { icon: 'truck', title: 'Nationwide Delivery', description: 'Licensed install crews in all 50 states.' },
];

const formatCurrency = (value: number) =>
  'R' + value.toLocaleString('en-ZA', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
---

<section class="bg-background text-foreground">
  <div class="border-b border-border bg-muted/20">
    <div class="mx-auto max-w-7xl px-4 py-6">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        {breadcrumbs.map((crumb, index) => (
          <div class="flex items-center">
            {index > 0 && <span class="px-1 text-muted-foreground">/</span>}
            {index === breadcrumbs.length - 1 ? (
              <span class="font-semibold text-foreground">{crumb.label}</span>
            ) : (
              <a href={crumb.href} class="transition hover:text-foreground">{crumb.label}</a>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-12 lg:grid lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] lg:gap-8">
    <div class="space-y-8">
      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-semibold">Shopping Cart</h1>
            <p class="text-sm text-muted-foreground">{cartItems.length} project {cartItems.length === 1 ? 'item' : 'items'} ready to review</p>
          </div>
          <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 7.5A1.5 1.5 0 013.75 6h9.5a1.5 1.5 0 011.5 1.5v6.75A2.25 2.25 0 0112.5 16.5h-6a2.25 2.25 0 01-2.25-2.25V7.5zM14.75 9h2a1.5 1.5 0 011.335.832l1.5 3A1.5 1.5 0 0118.25 15H14.75" /></svg>
            White-glove delivery included
          </div>
        </div>

        <div class="mt-6 space-y-6">
          {cartItems.map((item, index) => (
            <div class="space-y-4">
              {index > 0 && <hr class="border-border" />}
              <div class="flex items-center justify-between text-xs text-muted-foreground">
                <span>Arrives by {item.deliveryDate}</span>
                <span>{formatCurrency(item.price)} each • {item.quantity} unit</span>
              </div>
              <div class="flex flex-col gap-4 sm:flex-row">
                <div class="h-32 w-full overflow-hidden rounded-xl border border-border bg-muted/40 sm:w-32">
                  <img src={item.image} alt={item.name} class="h-full w-full object-cover" />
                </div>
                <div class="flex-1 space-y-3">
                  <div>
                    <a href={item.slug} class="text-base font-semibold transition hover:text-primary">{item.name}</a>
                    <div class="mt-1 text-sm text-muted-foreground">
                      <span>Finish: {item.color}</span>
                      <span class="px-2">•</span>
                      <span>Footprint: {item.size}</span>
                    </div>
                    <p class="mt-2 text-sm text-green-600">{item.shipping}</p>
                  </div>
                  {item.protection?.available && (
                    <div class="rounded-xl border border-border bg-muted/30 p-3">
                      <div class="flex items-center gap-2 text-sm font-semibold text-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" /></svg>
                        Add protection plan
                      </div>
                      <ul class="mt-2 space-y-2 text-sm text-muted-foreground">
                        {item.protection.plans.map((plan) => (
                          <li>{plan.years}-year coverage • {formatCurrency(plan.price)}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
                    <span class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1">Qty: {item.quantity}</span>
                    <span class="cursor-pointer transition hover:text-foreground">Save for later</span>
                    <span class="cursor-pointer text-primary transition hover:underline">See similar builds</span>
                  </div>
                </div>
                <div class="text-right text-sm">
                  <p class="text-lg font-semibold text-foreground">{formatCurrency(item.price * item.quantity)}</p>
                  {item.originalPrice && item.originalPrice > item.price && (
                    <div class="space-y-1">
                      <p class="text-sm text-muted-foreground line-through">{formatCurrency(item.originalPrice)}</p>
                      <p class="text-xs text-green-600">Project savings {formatCurrency((item.originalPrice - item.price) * item.quantity)}</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-lg font-semibold">Pickup & delivery options</h2>
        <p class="mt-1 text-sm text-muted-foreground">Schedule site delivery or arrange yard pickup with our logistics team.</p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {shippingOptions.map((option) => (
            <div class={`rounded-xl border ${option.id === selectedShipping.id ? 'border-primary' : 'border-border'} bg-muted/30 p-4`}> 
              <div class="flex items-center justify-between">
                <p class="font-medium text-foreground">{option.name}</p>
                <span class="text-xs font-semibold uppercase tracking-wide text-primary">{option.badge}</span>
              </div>
              <p class="mt-2 text-sm text-muted-foreground">{option.description}</p>
              <p class="mt-3 text-sm font-semibold text-foreground">{option.cost === 0 ? 'Included' : formatCurrency(option.cost)}</p>
              <p class="text-xs text-muted-foreground">{option.estimated}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <aside class="mt-8 space-y-6 lg:mt-0">
      <div class="rounded-2xl border border-border bg-muted/30 p-4 text-center text-sm text-muted-foreground">
        Returning client? <a href="/auth/login" class="font-semibold text-primary hover:underline">Sign in for saved projects</a>
      </div>

      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-lg font-semibold">Order summary</h2>
        <div class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-muted-foreground">Subtotal ({cartItems.length} items)</span>
            <span class="font-medium">{formatCurrency(subtotal)}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Projected savings</span>
            <span class="text-green-600">- {formatCurrency(savings)}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Delivery & install</span>
            <span class={shippingCost === 0 ? 'text-green-600' : 'font-medium text-foreground'}>{shippingCost === 0 ? 'Included' : formatCurrency(shippingCost)}</span>
          </div>
        </div>

        <div class="mt-6 space-y-2 text-sm">
          <p class="font-semibold text-foreground">Promo or financing code</p>
          <div class="flex items-center gap-2">
            <input type="text" placeholder="Enter code" class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
            <button class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90">Apply</button>
          </div>
        </div>

        <hr class="my-6 border-border" />

        <div class="flex items-center justify-between">
          <span class="text-base font-semibold text-foreground">Estimated total</span>
          <span class="text-2xl font-bold text-foreground">{formatCurrency(estimatedTotal)}</span>
        </div>
        <p class="mt-2 text-xs text-muted-foreground">Final freight quotes confirmed during checkout once site logistics are verified.</p>

        <a href="/checkout" class="mt-6 block rounded-full bg-primary px-6 py-3 text-center text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">Continue to checkout</a>

        <div class="mt-6 space-y-3 text-sm text-muted-foreground">
          <p class="font-semibold text-foreground">Accepted methods</p>
          <div class="flex flex-wrap gap-2">
            {acceptedMethods.map((method) => (
              <span class="inline-flex h-8 items-center justify-center rounded-md border border-border bg-muted/40 px-3 text-xs font-semibold">{method}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="space-y-4 rounded-2xl border border-border bg-muted/20 p-6 text-sm">
        {reassurance.map((item) => (
          <div class="flex items-start gap-3">
            <div class="mt-1 rounded-full bg-primary/10 p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                {item.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75c1.148-.849 2.667-1.5 4.5-1.5 1.833 0 3.352.651 4.5 1.5v4.5c0 4.5-3 8.25-9 11-6-2.75-9-6.5-9-11v-4.5c1.148-.849 2.667-1.5 4.5-1.5 1.833 0 3.352.651 4.5 1.5z" />}
                {item.icon === 'check' && <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />}
                {item.icon === 'truck' && <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h11v11H3zM14 8h4l3 4v5h-7" />}
              </svg>
            </div>
            <div>
              <p class="font-semibold text-foreground">{item.title}</p>
              <p class="text-xs text-muted-foreground">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>
