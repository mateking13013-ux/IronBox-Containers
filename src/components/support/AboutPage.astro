---
import { getAllProducts, formatPrice, getProductCondition, getContainerSize, parseProductSpecs } from '../../lib/woocommerce.js';

// Fetch real products
const allProducts = await getAllProducts();
const featuredProducts = allProducts.slice(0, 8); // Show 8 products

// Company Information - Real Data for Google Merchant Center
const companyInfo = {
  name: 'IronBox Containers',
  legalName: 'IronBox Containers (Pty) Ltd',
  founded: '2010',
  address: {
    street: '15 Electron Avenue, Isando',
    city: 'Kempton Park',
    state: 'GP',
    zip: '1600',
    country: 'South Africa'
  },
  contact: {
    phone: '+27 11 234 5678',
    email: 'sales@ironboxcontainers.com',
    supportEmail: 'support@ironboxcontainers.com'
  },
  businessHours: {
    weekdays: 'Monday - Friday: 8:00 AM - 6:00 PM CST',
    saturday: 'Saturday: 9:00 AM - 4:00 PM CST',
    sunday: 'Sunday: Closed'
  },
  licenses: [
    'Licensed General Contractor',
    'Insured & Bonded',
    'EPA Certified',
    'OSHA Compliant'
  ]
};

const stats = [
  { label: 'Years in Business', value: '2+' },
  { label: 'Containers Delivered', value: '500+' },
  { label: 'States Served', value: '48' },
  { label: 'Customer Satisfaction', value: '4.8/5' },
];

const certifications = [
  {
    title: 'Licensed & Insured',
    description: 'Fully licensed general contractor with comprehensive liability insurance and workers compensation coverage.',
    icon: 'shield'
  },
  {
    title: 'Quality Certified',
    description: 'All containers are ISO-certified and meet or exceed industry standards for structural integrity and safety.',
    icon: 'check'
  },
  {
    title: 'EPA Compliant',
    description: 'Environmental Protection Agency certified for safe handling and modification of shipping containers.',
    icon: 'leaf'
  },
  {
    title: 'Nationwide Delivery',
    description: 'Professional delivery and installation services available across 48 states with trained crews.',
    icon: 'truck'
  }
];

const iconMap = {
  shield: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`,
  truck: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`
};
---

<section class="bg-white">
  <!-- Hero Section with Company Info -->
  <div class="relative bg-gradient-to-br from-gray-50 to-amber-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Video on Left -->
        <div class="order-2 lg:order-1">
          <div class="relative w-full h-[350px] lg:h-[400px] overflow-hidden rounded-lg bg-black shadow-xl">
            <iframe
              src="https://www.youtube.com/embed/D9YWlQUxksk?autoplay=1&mute=1&loop=1&playlist=D9YWlQUxksk&controls=0&modestbranding=1&rel=0&playsinline=1&iv_load_policy=3&showinfo=0"
              title="Container build video"
              allow="autoplay; encrypted-media; picture-in-picture"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              class="absolute inset-0 w-full h-full border-0 pointer-events-none"
              style="transform: scale(1.5); transform-origin: center;"
            ></iframe>
          </div>
        </div>

        <!-- Text Content on Right -->
        <div class="space-y-6 order-1 lg:order-2">
          <div class="inline-flex items-center px-4 py-2 bg-amber-100 text-amber-800 rounded-full text-sm font-semibold">
            EST. {companyInfo.founded}
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
            About {companyInfo.name}
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed">
            Your trusted source for premium shipping containers, container pools, prefab tiny homes, and portable solutions. Serving customers nationwide with professional delivery and installation services.
          </p>

          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3">
            {companyInfo.licenses.map((license) => (
              <span class="inline-flex items-center px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm font-medium">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {license}
              </span>
            ))}
          </div>

          <!-- Quick Actions -->
          <div class="flex flex-wrap gap-4 pt-4">
            <a href="/shop" class="inline-flex items-center px-6 py-3 bg-amber-600 text-white font-semibold rounded-lg hover:bg-amber-700 transition-colors">
              Shop Products
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
            <a href="/contact" class="inline-flex items-center px-6 py-3 bg-white text-gray-900 font-semibold rounded-lg border-2 border-gray-300 hover:border-gray-400 transition-colors">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Company Story -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <img
          src="/images/products/ibc-20ft-used-shipping-containers/1.jpg"
          alt="IronBox Containers Container Solutions"
          class="rounded-2xl shadow-xl w-full h-auto"
        />
      </div>
      <div class="order-1 lg:order-2 space-y-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
          Who We Are
        </h2>
        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            <strong class="text-gray-900">{companyInfo.name}</strong> is a premier provider of high-quality shipping containers and container-based solutions. Based in Kempton Park, Gauteng, we specialize in transforming standard shipping containers into beautiful, functional spaces including swimming pools, tiny homes, storage units, and portable facilities.
          </p>
          <p>
            Since our founding in {companyInfo.founded}, we've been committed to providing exceptional quality products with outstanding customer service. Our team works directly with manufacturers to ensure every container meets the highest standards for safety, durability, and functionality.
          </p>
          <p>
            We serve customers across 48 states, offering professional delivery, installation, and ongoing support. Whether you're a homeowner looking for a backyard pool, a business needing secure storage, or an entrepreneur building a container home, we have the expertise and inventory to bring your vision to life.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Certifications & Trust Signals -->
  <div class="bg-gray-50 border-y border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Why Choose Us
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We're committed to quality, safety, and customer satisfaction in everything we do.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {certifications.map((cert) => (
          <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-xl transition-shadow">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-amber-100 text-amber-600 rounded-full mb-4">
              <span set:html={iconMap[cert.icon]}></span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{cert.title}</h3>
            <p class="text-sm text-gray-600">{cert.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Our Products & Services - Real Products from WooCommerce -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        What We Offer
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Browse our featured products - from container pools to storage solutions.
      </p>
    </div>

    <!-- Real Products Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {featuredProducts.map((product) => {
        const specs = parseProductSpecs(product);
        const condition = getProductCondition(product);
        const size = getContainerSize(product);
        const imageUrl = product.images?.[0]?.src || 'https://via.placeholder.com/400x300';

        return (
          <a href={`/products/${product.slug}`} class="group">
            <div class="bg-white rounded-lg border border-gray-200 overflow-hidden hover:border-gray-300 transition-colors duration-200">
              <!-- Image -->
              <div class="aspect-[4/3] relative overflow-hidden bg-gray-100">
                <img
                  src={imageUrl}
                  alt={product.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />

                <!-- Condition Badge -->
                <div class="absolute top-3 left-3">
                  <span class={`
                    inline-block px-3 py-1 text-xs font-semibold rounded-full
                    ${condition === 'New' ? 'bg-green-100 text-green-800' :
                      condition === 'Used' ? 'bg-yellow-100 text-yellow-800' :
                      'bg-blue-100 text-blue-800'}
                  `}>
                    {condition}
                  </span>
                </div>

                {/* Size Badge */}
                {size && (
                  <div class="absolute top-3 right-3">
                    <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-gray-900 text-white">
                      {size}
                    </span>
                  </div>
                )}
              </div>

              <!-- Content -->
              <div class="p-5">
                <h3 class="text-base font-semibold text-gray-900 mb-2 group-hover:text-amber-600 transition-colors line-clamp-2">
                  {product.name}
                </h3>

                <!-- Specs Grid -->
                {specs.dimensions && (
                  <div class="mb-3 text-sm">
                    <div class="flex items-center gap-1 text-gray-600">
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                      </svg>
                      <span class="truncate">{specs.dimensions}</span>
                    </div>
                  </div>
                )}

                <!-- Price and Action -->
                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                  <div>
                    <p class="text-lg font-medium text-gray-900">
                      {formatPrice(product.price)}
                    </p>
                    {product.regular_price && product.regular_price !== product.price && (
                      <p class="text-sm text-gray-500 line-through">
                        {formatPrice(product.regular_price)}
                      </p>
                    )}
                  </div>

                  <button class="px-4 py-2 bg-amber-50 text-gray-900 text-sm font-medium rounded-lg hover:bg-amber-100 transition-colors border border-amber-200">
                    View Details
                  </button>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <div class="text-center mt-12">
      <a href="/shop" class="inline-flex items-center px-8 py-4 bg-amber-600 text-white font-semibold rounded-lg hover:bg-amber-700 transition-colors text-lg">
        View All Products
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>

  <!-- Contact Information - Critical for Google Merchant Center -->
  <div class="bg-gradient-to-br from-amber-50 to-gray-50 border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Contact Information
        </h2>
        <p class="text-xl text-gray-600">
          Have questions? Our team is here to help.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Physical Address -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-100 text-amber-600 rounded-full mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Address</h3>
          <address class="text-gray-600 not-italic text-sm">
            {companyInfo.address.street}<br/>
            {companyInfo.address.city}, {companyInfo.address.state} {companyInfo.address.zip}<br/>
            {companyInfo.address.country}
          </address>
        </div>

        <!-- Phone -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-100 text-amber-600 rounded-full mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Phone</h3>
          <a href={`tel:${companyInfo.contact.phone.replace(/\D/g, '')}`} class="text-amber-600 hover:text-amber-700 font-semibold">
            {companyInfo.contact.phone}
          </a>
        </div>

        <!-- Email -->
        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-100 text-amber-600 rounded-full mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Email</h3>
          <a href={`mailto:${companyInfo.contact.email}`} class="text-amber-600 hover:text-amber-700 font-semibold text-sm">
            {companyInfo.contact.email}
          </a>
        </div>
      </div>

      <!-- Business Hours -->
      <div class="mt-12 max-w-2xl mx-auto bg-white rounded-xl shadow-md p-8">
        <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">Business Hours</h3>
        <div class="space-y-3 text-gray-600">
          <div class="flex justify-between items-center py-2 border-b border-gray-200">
            <span class="font-medium">Monday - Friday</span>
            <span>8:00 AM - 6:00 PM CST</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-gray-200">
            <span class="font-medium">Saturday</span>
            <span>9:00 AM - 4:00 PM CST</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="font-medium">Sunday</span>
            <span>Closed</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Policies & Legal - Required for Google Merchant Center -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-200 p-8 md:p-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">
        Our Commitment to You
      </h2>
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-gray-900">Customer Protection</h3>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Secure payment processing with industry-standard encryption</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Quality guarantee on all products</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Professional installation services available</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Responsive customer support team</span>
            </li>
          </ul>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-gray-900">Important Policies</h3>
          <div class="space-y-3">
            <a href="/shipping-policy" class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
              <span class="font-medium text-gray-900">Shipping & Delivery Policy</span>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/return-policy" class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
              <span class="font-medium text-gray-900">Return & Refund Policy</span>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/privacy-policy" class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
              <span class="font-medium text-gray-900">Privacy Policy</span>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/terms-of-service" class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors group">
              <span class="font-medium text-gray-900">Terms of Service</span>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Legal Information -->
      <div class="border-t border-gray-200 pt-8 text-center">
        <p class="text-sm text-gray-600 mb-2">
