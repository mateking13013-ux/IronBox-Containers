---
interface Props {
	title: string;
	lastUpdated?: string;
	children?: any;
	productCategories?: Array<{name: string; href: string;}>;
}

const { title, lastUpdated = "Updated July 1, 2024", children, productCategories } = Astro.props;

const allPolicies = [
	{ name: "Privacy Policy", href: "/privacy-policy" },
	{ name: "Terms of Service", href: "/terms-of-service" },
	{ name: "Return & Warranty Policy", href: "/return-policy" },
	{ name: "Shipping & Installation Policy", href: "/shipping-policy" },
	{ name: "Cookie Policy", href: "/cookie-policy" },
	{ name: "Accessibility Policy", href: "/accessibility" },
	{ name: "Data Protection Policy", href: "/data-protection" },
	{ name: "GDPR Compliance", href: "/gdpr" }
];

const contactDetails = {
	phone: "+27 11 234 5678",
	email: "support@ironboxcontainers.com",
	address: "15 Electron Avenue, Isando, Kempton Park, Gauteng, 1600"
};

// Use actual WordPress WooCommerce categories
let categories = productCategories;

if (!categories) {
	// Real WordPress product categories with updated English slugs
	categories = [
		{ name: "20ft Containers", href: "/categories/20ft-container" },
		{ name: "40ft Containers", href: "/categories/40ft-container" },
		{ name: "10ft Containers", href: "/categories/10ft-container" },
		{ name: "Storage Containers", href: "/categories/storage-container" },
		{ name: "Modified Containers", href: "/categories/modified-container" },
		{ name: "Refrigerated Containers", href: "/categories/refrigerated-container" },
		{ name: "16ft Containers", href: "/categories/16ft-container" },
		{ name: "Open Side Containers", href: "/categories/open-side-container" },
		{ name: "30ft Containers", href: "/categories/30ft-container" },
		{ name: "24ft Containers", href: "/categories/24ft-container" }
	];
}
---
<section class="bg-background text-foreground min-h-screen">
	<!-- Policy Header with Background Image -->
	<div class="relative h-72 overflow-hidden">
		<div class="absolute inset-0">
			<img 
				src="/images/branding/banner-policy-header.jpg"
				alt="Policy Header"
				class="w-full h-full object-cover"
				style="object-position: center; filter: brightness(0.7);"
			/>
		</div>
		<div class="absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-black/30"></div>
		<div class="absolute inset-0 flex items-center">
			<div class="mx-auto max-w-7xl px-4 md:px-8 w-full">
				<h1 class="text-4xl font-bold text-white mb-2">{title}</h1>
				<p class="text-white/90 text-sm">{lastUpdated}</p>
			</div>
		</div>
	</div>

	<!-- Breadcrumbs -->
	<div class="border-b border-border bg-muted/30">
		<div class="mx-auto max-w-7xl px-4 py-3">
			<nav aria-label="Breadcrumb" class="flex items-center space-x-2 text-sm text-muted-foreground">
				<a href="/" class="hover:text-foreground transition-colors">Home</a>
				<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
				</svg>
				<span class="text-foreground font-medium">{title}</span>
			</nav>
		</div>
	</div>

	<!-- Main Content with Sidebar -->
	<div class="mx-auto max-w-7xl px-4 py-8">
		<div class="flex flex-col lg:flex-row gap-8">
			<!-- Main Content Area (70% or more) -->
			<main class="flex-1 lg:min-w-0 lg:order-1 order-1">
				<slot />
			</main>

			<!-- Sidebar (30% on desktop, full width on mobile) -->
			<aside class="w-full lg:w-80 lg:order-2 order-2">
				<div class="bg-[#FFFACD] rounded-xl p-3 space-y-3">
					<!-- Policies Menu -->
					<div class="space-y-1">
						<h3 class="text-base font-bold text-gray-800 mb-2">Policies</h3>
						{allPolicies.map((policy) => (
							<a 
								href={policy.href} 
								class="block bg-white border border-gray-200 rounded px-3 py-2 hover:bg-[#FF9800] hover:border-[#FF9800] hover:text-white transition-all duration-300"
							>
								<div class="flex items-center justify-between">
									<span class="text-xs font-medium text-gray-700 hover:text-white">{policy.name}</span>
									<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-400 hover:text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
									</svg>
								</div>
							</a>
						))}
					</div>

					<div class="border-t border-yellow-200 pt-2"></div>

					<!-- Product Categories -->
					<div class="space-y-1">
						<h3 class="text-base font-bold text-gray-800 mb-2">Categories</h3>
						{categories.slice(0, 6).map((category) => (
							<a 
								href={category.href} 
								class="block bg-white border border-gray-200 rounded px-3 py-2 hover:bg-[#FF9800] hover:border-[#FF9800] hover:text-white transition-all duration-300 mb-1"
							>
								<div class="flex items-center justify-between">
									<span class="text-xs font-medium text-gray-700 hover:text-white">{category.name}</span>
									<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-400 hover:text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
									</svg>
								</div>
							</a>
						))}
						{categories.length > 6 && (
							<details class="group">
								<summary class="flex items-center justify-between px-3 py-2 text-xs font-bold text-gray-700 cursor-pointer hover:text-orange-600">
									<span>More Categories</span>
									<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-400 group-open:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
									</svg>
								</summary>
								<div class="pl-3 space-y-1">
									{categories.slice(6).map((category) => (
										<a 
											href={category.href} 
											class="block bg-white border border-gray-200 rounded px-3 py-2 hover:bg-[#FF9800] hover:border-[#FF9800] hover:text-white transition-all duration-300 mb-1"
										>
											<div class="flex items-center justify-between">
												<span class="text-xs font-medium text-gray-700 hover:text-white">{category.name}</span>
												<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-400 hover:text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
													<path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
												</svg>
											</div>
										</a>
									))}
								</div>
							</details>
						)}
					</div>

					<div class="border-t border-yellow-300 pt-4"></div>

					<!-- Contact Details -->
					<div class="space-y-2">
						<h3 class="text-lg font-bold text-gray-800 mb-3">Contact Us</h3>
						
						<div class="bg-white border border-gray-200 rounded-md p-4 space-y-3">
							<div class="flex items-center gap-3">
								<div class="bg-[#FFFACD] rounded-full p-2">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#FF9800]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 17.25V6.75M19.5 12c0 1.121-.939 2-2.087 2H6.587c-1.148 0-2.087-.879-2.087-2s.939-2 2.087-2h10.826c1.148 0 2.087.879 2.087 2z" />
									</svg>
								</div>
								<div>
									<p class="text-xs font-semibold text-gray-600">PHONE</p>
									<p class="text-sm font-bold text-gray-800">{contactDetails.phone}</p>
								</div>
							</div>

							<div class="flex items-center gap-3">
								<div class="bg-[#FFFACD] rounded-full p-2">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#FF9800]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 17.25V6.75m19.5 0A2.25 2.25 0 0 0 21.75 4.5H6.75A2.25 2.25 0 0 0 4.5 6.75m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
									</svg>
								</div>
								<div>
									<p class="text-xs font-semibold text-gray-600">EMAIL</p>
									<p class="text-sm font-bold text-gray-800">{contactDetails.email}</p>
								</div>
							</div>

							<div class="flex items-start gap-3">
								<div class="bg-[#FFFACD] rounded-full p-2">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#FF9800]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
										<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
									</svg>
								</div>
								<div class="flex-1">
									<p class="text-xs font-semibold text-gray-600">ADDRESS</p>
									<p class="text-sm font-bold text-gray-800">{contactDetails.address}</p>
								</div>
							</div>

							<a href="/contact" class="block w-full bg-[#FF9800] text-white text-center py-3 px-4 rounded-md font-bold hover:bg-orange-600 transition-colors text-sm">
								Contact Support
							</a>
						</div>
					</div>
				</div>
			</aside>
		</div>
	</div>
</section>
