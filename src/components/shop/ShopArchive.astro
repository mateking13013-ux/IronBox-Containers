---
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Shop', href: '/shop' },
];

const hero = {
  title: 'Shop All Container Solutions',
  description:
    'Discover container pools, prefab homes, portable restrooms, and storage suites engineered for fast deployment and premium finishes.',
  image:
    'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=1600&q=80',
  promo: {
    headline: 'Professional Delivery & Installation',
    subheadline: 'Nationwide crane placement with licensed crews across all provinces.',
    cta: { label: 'View Special Offers', href: '/contact' },
  },
  stats: [
    { label: 'Products curated', value: '86' },
    { label: 'Lead time', value: '6-8 weeks' },
    { label: 'Customer rating', value: '4.8/5' },
  ],
};

const filters = {
  categories: [
    { label: 'Container Pools', count: 18, href: '/categories/container-swimming-pools' },
    { label: 'Prefab Homes', count: 12, href: '/categories/prefab-homes' },
    { label: 'Portable Restrooms', count: 9, href: '/categories/portable-restrooms' },
    { label: 'Storage Containers', count: 21, href: '/categories/storage-container' },
    { label: 'Office Suites', count: 7, href: '/categories/mobile-office-suites' },
  ],
  priceRanges: [
    { label: 'Under $10k', min: 0, max: 10000 },
    { label: '$10k - $25k', min: 10000, max: 25000 },
    { label: '$25k - $50k', min: 25000, max: 50000 },
    { label: '$50k+', min: 50000, max: 1000000 },
  ],
  ratings: [
    { label: '4 stars & up', value: 4 },
    { label: '4.5 stars & up', value: 4.5 },
    { label: '5 stars', value: 5 },
  ],
  highlights: ['Featured', 'Best Seller', 'Quick Ship', 'Financing Ready', 'Ready-to-install'],
};

const logistics = [
  { title: 'Financing Ready', description: 'Partner lenders with rates as low as 5.9% APR.' },
  { title: 'White-glove Delivery', description: 'Crane placement coordinated in all 9 provinces.' },
  { title: 'Permit Support', description: 'Engineered drawings and site plan assistance included.' },
];

const products = [
  {
