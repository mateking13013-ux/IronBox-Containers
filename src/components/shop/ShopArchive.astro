    price: '$198,500',
    originalPrice: '$214,900',
    rating: '4.9',
    reviews: 87,
    badge: 'Featured',
    image: 'https://images.unsplash.com/photo-1600585154340-0ef3c08ba6b0?auto=format&fit=crop&w=900&q=80',
    href: '/products/summit-prefab-home',
  },
  {
    name: 'Executive Restroom Suite',
    description: 'Luxury restroom trailer with quartz vanities and climate control.',
    price: '$21,900',
    originalPrice: '$23,500',
    rating: '4.7',
    reviews: 56,
    badge: 'Quick Ship',
    image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=900&q=80',
    href: '/products/executive-restroom-suite',
  },
  {
    name: 'Secure Storage Plus',
    description: 'Climate-controlled storage container with roll-up access and security package.',
    price: '$10,200',
    rating: '4.6',
    reviews: 42,
    badge: 'Industrial',
    image: 'https://images.unsplash.com/photo-1503389152951-9f343605f61e?auto=format&fit=crop&w=900&q=80',
    href: '/products/secure-storage-plus',
  },
  {
    name: 'Coastal Retreat ADU',
    description: 'Accessory dwelling unit with full kitchen, bath, and lofted sleeping space.',
    price: '$156,000',
    originalPrice: '$169,000',
    rating: '4.9',
    reviews: 68,
    badge: 'Limited Stock',
    image: 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=900&q=80',
    href: '/products/coastal-retreat-adu',
  },
  {
    name: 'Modern Site Office Pod',
    description: 'Modular office pod with glass frontage and flexible workspace interior.',
    price: '$32,400',
    originalPrice: '$36,000',
    rating: '4.5',
    reviews: 35,
    badge: 'New Arrival',
    image: 'https://images.unsplash.com/photo-1529421306624-0f59bd09f1f8?auto=format&fit=crop&w=900&q=80',
    href: '/products/modern-site-office-pod',
  },
  {
    name: 'Vista Series Glass Pool',
    description: 'Glass-sided container pool with submerged lounge deck and LED package.',
    price: '$42,800',
    rating: '4.8',
    reviews: 51,
    badge: 'Design Award',
    image: 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&w=900&q=80',
    href: '/products/vista-series-glass-pool',
  },
  {
    name: 'Trailblazer Mobile Office',
    description: 'Two-room mobile office with conference pod and integrated storage.',
    price: '$54,900',
    rating: '4.6',
    reviews: 39,
    badge: 'Commercial',
    image: 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&fit=crop&w=900&q=80',
