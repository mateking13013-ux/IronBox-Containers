    description: 'Turnkey swimming pool delivered craned into place with automation suite.',
    price: '$24,500',
    originalPrice: '$28,900',
    rating: '4.8',
    reviews: 124,
    badge: 'Best Seller',
    image: 'https://images.unsplash.com/photo-1616628188410-5fe5b3ba1f80?auto=format&fit=crop&w=900&q=80',
    href: '/products/signature-container-pool-30ft',
  },
  {
