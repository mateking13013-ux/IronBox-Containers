const sortOptions = ['Featured', 'Price: Low to High', 'Price: High to Low', 'Newest', 'Top Rated'];

const pagination = {
  showing: 'Showing 1-12 of 86 products',
  current: 1,
  total: 5,
};
---

<section class="w-full bg-background">
  <div class="border-b border-border bg-muted/20">
    <div class="mx-auto max-w-7xl px-4 py-4">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        {breadcrumbs.map((crumb, index) => (
          <div class="flex items-center" >
            {index > 0 && <span class="px-1 text-muted-foreground">/</span>}
            {index === breadcrumbs.length - 1 ? (
              <span class="font-semibold text-foreground">{crumb.label}</span>
            ) : (
              <a href={crumb.href} class="transition hover:text-foreground">{crumb.label}</a>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>

  <div class="border-b border-border bg-gradient-to-r from-primary/10 to-accent/10">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 lg:grid-cols-[minmax(0,1fr)_420px] lg:items-center">
      <div class="space-y-6">
        <div class="space-y-4">
          <h1 class="text-3xl font-bold text-foreground md:text-4xl">{hero.title}</h1>
          <p class="text-lg text-muted-foreground md:text-xl">{hero.description}</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {hero.stats.map((stat) => (
            <div class="rounded-2xl border border-border bg-card/80 p-4 shadow-sm">
              <p class="text-2xl font-semibold text-foreground">{stat.value}</p>
              <p class="text-sm text-muted-foreground">{stat.label}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-wrap gap-4 rounded-2xl border border-border bg-card p-5 shadow-sm">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">{hero.promo.headline}</p>
            <p class="mt-2 text-sm text-muted-foreground">{hero.promo.subheadline}</p>
          </div>
          <a href={hero.promo.cta.href} class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
            {hero.promo.cta.label}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
      <div class="relative hidden overflow-hidden rounded-3xl border border-border shadow-lg md:block">
        <img src={hero.image} alt="Container pool" class="h-full w-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        <div class="absolute bottom-6 left-6 space-y-1 text-white">
          <p class="text-xs font-semibold uppercase tracking-wide text-white/80">Turnkey delivery</p>
          <p class="text-2xl font-semibold">Signature Series Container Pool</p>
          <p class="text-sm text-white/80">Crane set in one afternoon with licensed crew</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-12 lg:grid lg:grid-cols-[300px_minmax(0,1fr)] lg:gap-12">
    <aside class="mb-10 space-y-8 lg:mb-0">
      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Categories</h2>
          <a href="/categories" class="text-xs font-semibold text-primary hover:underline">View all</a>
        </div>
        <ul class="mt-4 space-y-3 text-sm text-muted-foreground">
          {filters.categories.map((cat) => (
            <li class="flex items-center justify-between rounded-lg px-2 py-1 transition hover:bg-muted/60">
              <a href={cat.href} class="flex-1">
                {cat.label}
              </a>
              <span class="rounded-full bg-muted px-2 py-0.5 text-xs text-muted-foreground">{cat.count}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Price Range</h2>
        <div class="mt-5 space-y-3 text-sm text-muted-foreground">
          {filters.priceRanges.map((range) => (
            <label class="flex cursor-pointer items-center gap-3">
              <span class="relative inline-flex h-4 w-4 items-center justify-center rounded-full border border-border">
                <span class="h-2 w-2 rounded-full bg-primary/70"></span>
              </span>
              {range.label}
            </label>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Customer Rating</h2>
        <div class="mt-4 space-y-2 text-sm text-muted-foreground">
          {filters.ratings.map((rating) => (
            <label class="flex cursor-pointer items-center gap-2">
              <input type="checkbox" class="h-4 w-4 rounded border border-border" />
              <span>{rating.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Availability</h2>
        <label class="mt-4 flex cursor-pointer items-center gap-2 text-sm text-muted-foreground">
          <input type="checkbox" class="h-4 w-4 rounded border border-border" checked />
          In stock only
        </label>
      </div>

      <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Highlights</h2>
        <div class="mt-4 flex flex-wrap gap-2 text-xs">
          {filters.highlights.map((highlight) => (
            <span class="rounded-full border border-border px-3 py-1 text-muted-foreground transition hover:border-primary hover:text-primary">{highlight}</span>
          ))}
        </div>
      </div>
    </aside>

    <div class="space-y-10">
      <div class="flex flex-col gap-4 rounded-2xl border border-border bg-card p-5 shadow-sm md:flex-row md:items-center md:justify-between">
        <div class="space-y-1 text-sm text-muted-foreground">
          <span class="font-medium text-foreground">{pagination.showing}</span>
          <span>Use filters to refine install-ready products.</span>
        </div>
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:gap-4">
          <label class="flex items-center gap-2 text-sm text-muted-foreground">
            Sort by
            <select class="rounded-lg border border-border bg-background px-3 py-2 text-sm">
              {sortOptions.map((option) => (
                <option>{option}</option>
              ))}
            </select>
          </label>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <button class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border transition hover:bg-muted" aria-label="Grid view">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.5h4.5v4.5h-4.5V4.5zM15.75 4.5h4.5v4.5h-4.5V4.5zM3.75 15h4.5v4.5h-4.5V15zM15.75 15h4.5v4.5h-4.5V15z" /></svg>
            </button>
            <button class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border transition hover:bg-muted" aria-label="List view">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M3 12h18M3 18h18" /></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {products.map((product) => (
          <a href={product.href} class="group">
            <div class="flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
              <div class="relative aspect-[4/3]">
                <img src={product.image} alt={product.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                {product.badge && (
                  <div class="absolute top-3 right-3 rounded-full bg-black/60 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
                    {product.badge}
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col gap-3 p-4">
                <div class="flex items-center gap-1 text-sm text-warning">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M11.48 3.499a.75.75 0 011.04 0l2.56 2.401 3.38.49a.75.75 0 01.415 1.28l-2.447 2.384.578 3.366a.75.75 0 01-1.088.79L12 12.347l-3.038 1.597a.75.75 0 01-1.088-.79l.578-3.366-2.447-2.384a.75.75 0 01.415-1.28l3.38-.49 2.56-2.401z" /></svg>
                  <span class="font-medium text-muted-foreground">{product.rating}</span>
                  <span class="text-xs text-muted-foreground">({product.reviews})</span>
                </div>
                <div class="space-y-1">
                  <h3 class="text-base font-semibold text-foreground transition group-hover:text-primary">{product.name}</h3>
                  <p class="text-sm text-muted-foreground">{product.description}</p>
                </div>
                <div class="mt-auto flex items-center gap-2">
                  <span class="text-lg font-semibold text-primary">{product.price}</span>
                  {product.originalPrice && <span class="text-sm text-muted-foreground line-through">{product.originalPrice}</span>}
                </div>
                <p class="text-xs uppercase tracking-wide text-muted-foreground">Nationwide install • Crane set in one day</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="flex flex-col items-center justify-between gap-4 rounded-2xl border border-border bg-card p-5 text-sm text-muted-foreground md:flex-row">
        <span>{pagination.showing}</span>
        <div class="flex items-center gap-2">
          <button class="rounded-full border border-border px-3 py-1 transition hover:bg-muted">Prev</button>
          {Array.from({ length: pagination.total }).map((_, index) => (
            <button class={`rounded-full px-3 py-1 transition ${index + 1 === pagination.current ? 'bg-primary font-semibold text-primary-foreground' : 'border border-border hover:bg-muted'}`}>
              {index + 1}
            </button>
          ))}
          <button class="rounded-full border border-border px-3 py-1 transition hover:bg-muted">Next</button>
        </div>
      </div>

      <div class="grid gap-4 rounded-2xl border border-border bg-muted/40 p-6 md:grid-cols-3">
        {logistics.map((item) => (
          <div class="space-y-2">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">{item.title}</h3>
            <p class="text-sm text-muted-foreground">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
