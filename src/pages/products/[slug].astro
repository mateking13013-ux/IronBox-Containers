---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllProducts, getCategories, formatPrice, getProductCondition, getContainerSize, parseProductSpecs } from '../../lib/woocommerce.js';

// Get all products for static paths
export async function getStaticPaths() {
  const products = await getAllProducts();

  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const { slug } = Astro.params;

// Parse product details
const condition = getProductCondition(product);
const size = getContainerSize(product);
const specs = parseProductSpecs(product);
const shippingClassLabel = product.shipping_class
  ? product.shipping_class.replace(/-/g, ' ')
  : 'Freight shipping (LTL/FTL)';
const weightText = product.weight ? `${product.weight} lbs` : 'Weight provided on freight quote';
const dimensionsText =
  product.dimensions &&
  (product.dimensions.length || product.dimensions.width || product.dimensions.height)
    ? `${product.dimensions.length || '—'} × ${product.dimensions.width || '—'} × ${product.dimensions.height || '—'} in`
    : 'Dimensions confirmed on quote';

// Get related products (same category)
const allProducts = await getAllProducts();
const relatedProducts = allProducts
  .filter(p => p.id !== product.id && p.categories?.some(c => product.categories?.some(pc => pc.id === c.id)))
  .slice(0, 4);

// Extract key features from description
const features = [
  'ISO/CSC Certified',
  'Weatherproof & Watertight',
  'Stackable Design',
  'Forklift Pockets',
  'Security Lockbox',
  'Ventilation System'
];

// Shipping info
const shippingInfo = {
  availability: product.stock_status === 'instock' ? 'In Stock - Ready to Ship' : 'Available to Order',
  deliveryTime: '5-10 business days',
  shippingCost: 'Calculated at Checkout',
  shippingClass: shippingClassLabel,
  locations: 'Ships Nationwide (USA)'
};

// Build structured data for Google
const structuredData = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": product.name,
  "image": product.images?.map(img => img.src) || [],
  "description": product.short_description?.replace(/<[^>]*>/g, '') || '',
  "sku": product.sku || `CONT-${product.id}`,
  "mpn": product.sku || `CONT-${product.id}`,
  "brand": {
    "@type": "Brand",
    "name": "IronBox Containers"
  },
  "offers": {
    "@type": "Offer",
    "url": `https://ironboxcontainers.co.za/products/${product.slug}`,
    "priceCurrency": "ZAR",
    "price": product.price,
    "availability": product.stock_status === 'instock' ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
    "seller": {
      "@type": "Organization",
      "name": "IronBox Containers"
    }
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://ironboxcontainers.co.za"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Shop",
      "item": "https://ironboxcontainers.co.za/shop"
    },
    ...(product.categories || []).map((cat, index) => ({
      "@type": "ListItem",
      "position": index + 3,
      "name": cat.name,
      "item": `https://ironboxcontainers.co.za/categories/${cat.slug}`
    })),
    {
      "@type": "ListItem",
      "position": (product.categories?.length || 0) + 3,
      "name": product.name,
      "item": `https://ironboxcontainers.co.za/products/${product.slug}`
    }
  ]
};
---

<MainLayout title={`${product.name} - IronBox Containers`} description={specs.description || product.short_description?.replace(/<[^>]*>/g, '').substring(0, 160)}>
  <!-- Structured Data for Google -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>

  <Header />
  <main class="pt-0">
    <!-- Breadcrumb -->
    <div class="bg-gray-50 border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <nav class="text-sm">
          <ol class="flex items-center space-x-2 flex-wrap">
            <li><a href="/" class="text-gray-500 hover:text-gray-700 hover:underline">Home</a></li>
            <li><span class="text-gray-400 mx-2">/</span></li>
            <li><a href="/shop" class="text-gray-500 hover:text-gray-700 hover:underline">Shop</a></li>
            {product.categories?.map((cat, index) => (
              <>
                <li><span class="text-gray-400 mx-2">/</span></li>
                <li><a href={`/categories/${cat.slug}`} class="text-gray-500 hover:text-gray-700 hover:underline">{cat.name}</a></li>
              </>
            ))}
            <li><span class="text-gray-400 mx-2">/</span></li>
            <li class="text-gray-900 font-medium truncate">{product.name}</li>
          </ol>
        </nav>
      </div>
    </div>

    <!-- Product Hero Section -->
    <section class="bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
        <div class="lg:grid lg:grid-cols-2 lg:gap-12">

          <!-- Product Gallery -->
          <div class="mb-8 lg:mb-0">
            <div class="relative">
              <!-- Main Image -->
              <div class="aspect-[4/3] overflow-hidden rounded-lg bg-gray-100">
                {product.images && product.images.length > 0 ? (
                  <img
                    src={product.images[0].src}
                    alt={product.name}
                    class="w-full h-full object-cover"
                    id="main-image"
                  />
                ) : (
                  <div class="flex items-center justify-center h-full bg-gray-100">
                    <span class="text-gray-400">Image coming soon</span>
                  </div>
                )}

                <!-- Badges -->
                <div class="absolute top-4 left-4 flex gap-2">
                  <span class={`
                    inline-block px-3 py-1 text-xs font-semibold rounded-full
                    ${condition === 'New' ? 'bg-green-100 text-green-800' :
                      condition === 'Used' ? 'bg-yellow-100 text-yellow-800' :
                      'bg-blue-100 text-blue-800'}
                  `}>
                    {condition}
                  </span>
                  <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-gray-900 text-white">
                    {size}
                  </span>
                </div>
              </div>

              <!-- Thumbnail Gallery -->
              {product.images && product.images.length > 1 && (
                <div class="mt-4 grid grid-cols-4 gap-3">
                  {product.images.map((image, index) => (
                    <button
                      class="aspect-square rounded-lg overflow-hidden bg-gray-100 border-2 border-transparent hover:border-blue-500 focus:border-blue-500 focus:outline-none"
                      onclick={`document.getElementById('main-image').src = '${image.src}'`}
                    >
                      <img src={image.src} alt={`${product.name} view ${index + 1}`} class="w-full h-full object-cover" />
                    </button>
                  ))}
                </div>
              )}
            </div>
          </div>

          <!-- Product Info -->
          <div>
            <!-- Title & SKU -->
            <div class="mb-4">
              <h1 class="text-3xl font-bold text-gray-900 mb-2">{product.name}</h1>
              <div class="text-sm text-gray-600 flex items-center flex-wrap gap-2">
                <span>SKU: <span class="font-medium">{product.sku || `CONT-${product.id}`}</span></span>
                <span>|</span>
                <span>Category:
                  {product.categories?.map((cat, index) => (
                    <>
                      {index > 0 && <span>, </span>}
                      <a href={`/categories/${cat.slug}`} class="font-medium text-blue-600 hover:text-blue-700 hover:underline">
                        {cat.name}
                      </a>
                    </>
                  ))}
                </span>
              </div>
            </div>

            <!-- Price -->
            <div class="mb-6 pb-6 border-b">
              <div class="flex items-baseline gap-3">
                <span class="text-4xl font-bold text-gray-900">{formatPrice(product.price)}</span>
                {product.regular_price && product.regular_price !== product.price && (
                  <>
                    <span class="text-2xl text-gray-500 line-through">{formatPrice(product.regular_price)}</span>
                    <span class="px-2 py-1 bg-red-100 text-red-800 text-sm font-semibold rounded">
                      Save {Math.round((1 - product.price/product.regular_price) * 100)}%
                    </span>
                  </>
                )}
              </div>
              <div class="mt-3 space-y-1 text-sm text-gray-700">
                <p><span class="font-semibold">Shipping:</span> {shippingClassLabel}</p>
                <p><span class="font-semibold">Weight:</span> {weightText}</p>
                <p><span class="font-semibold">Dimensions:</span> {dimensionsText}</p>
                <p><span class="font-semibold">Delivery window:</span> {shippingInfo.deliveryTime}</p>
                <p class="text-gray-600">Nationwide freight; signature required. We confirm liftgate/crane needs when you request a quote.</p>
                <a href="/shipping-policy" class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-700 hover:underline">
                  View shipping policy
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" /></svg>
                </a>
              </div>
            </div>

            <!-- Quick Specs from Short Description -->
            <div class="mb-6 pb-6 border-b">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Quick Specifications</h3>
              <div class="prose prose-sm text-gray-600" set:html={product.short_description}></div>
            </div>

            <!-- Key Features -->
            <div class="mb-6 pb-6 border-b">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Key Features</h3>
              <div class="grid grid-cols-2 gap-3">
                {features.map(feature => (
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-gray-700">{feature}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Shipping & Availability -->
            <div class="mb-8 pb-6 border-b">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Shipping & Availability</h3>
              <div class="space-y-2">
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm font-medium text-gray-900">{shippingInfo.availability}</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-sm text-gray-600">Delivery: {shippingInfo.deliveryTime}</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path>
                  </svg>
                  <span class="text-sm text-gray-600">{shippingInfo.shippingClass} • {shippingInfo.locations}</span>
                </div>
              </div>
            </div>

            <!-- Quantity and Add to Cart -->
            <div class="space-y-4">
              <!-- Quantity Selector -->
              <div class="flex items-center gap-4">
                <label for="quantity" class="text-sm font-medium text-gray-700">Quantity:</label>
                <div class="flex items-center border border-gray-300 rounded-lg">
                  <button
                    id="decrease-qty"
                    class="px-3 py-2 text-gray-600 hover:bg-gray-100 rounded-l-lg transition-colors"
                    type="button"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                    </svg>
                  </button>
                  <input
                    type="number"
                    id="quantity"
                    name="quantity"
                    class="w-16 px-2 py-2 text-center border-x border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500"
                  />
                  <button
                    id="increase-qty"
                    class="px-3 py-2 text-gray-600 hover:bg-gray-100 rounded-r-lg transition-colors"
                    type="button"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                  </button>
                </div>
              </div>

              <!-- CTA Buttons -->
              <div class="flex gap-3">
                <button
                  id="add-to-cart"
                  data-product={JSON.stringify({
                    id: product.id,
                    name: product.name,
                    price: product.price,
                    slug: product.slug,
                    sku: product.sku || `CONT-${product.id}`,
                    images: product.images
                  })}
                  class="flex-1 px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors flex items-center justify-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                  Add to Cart
                </button>
                <button class="flex-1 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">
                  Get Shipping Quote
                </button>
              </div>

              <button class="w-full px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg border-2 border-blue-600 hover:bg-blue-50 transition-colors">
                Request More Information
              </button>
              <div class="flex gap-3">
                <button class="flex-1 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                  Save to Wishlist
                </button>
                <button class="flex-1 px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-colors flex items-center justify-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m9.032 4.026a9.001 9.001 0 01-7.432 0m9.032-4.026A9.001 9.001 0 0112 3c-4.474 0-8.268 3.12-9.032 7.326m0 0A9.001 9.001 0 0012 21c4.474 0 8.268-3.12 9.032-7.326"></path>
                  </svg>
                  Share Product
                </button>
              </div>
            </div>

            <!-- Trust Badges -->
            <div class="mt-6 pt-6 border-t grid grid-cols-3 gap-4 text-center">
              <div>
                <svg class="w-8 h-8 text-blue-600 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                <p class="text-xs font-medium text-gray-700">ISO/CSC Certified</p>
              </div>
              <div>
                <svg class="w-8 h-8 text-green-600 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <p class="text-xs font-medium text-gray-700">Quality Inspected</p>
              </div>
              <div>
                <svg class="w-8 h-8 text-purple-600 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-xs font-medium text-gray-700">Best Price Guarantee</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Details Tabs -->
    <section class="bg-gray-50 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Tab Navigation -->
        <div class="border-b border-gray-200 bg-white rounded-t-lg">
          <nav class="flex space-x-8 px-6" aria-label="Tabs">
            <button class="py-4 px-1 border-b-2 border-blue-500 font-medium text-sm text-blue-600">
              Description
            </button>
            <button class="py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300">
              Specifications
            </button>
            <button class="py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300">
              Shipping Info
            </button>
            <button class="py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300">
              Warranty
            </button>
          </nav>
        </div>

        <!-- Tab Content -->
        <div class="bg-white rounded-b-lg p-6">
          <!-- Description Tab (Active) -->
          <div class="prose prose-gray max-w-none">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Product Description</h2>
            <div set:html={product.description}></div>

            <!-- Additional Info -->
            <div class="mt-8 grid md:grid-cols-2 gap-6">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Ideal Applications</h3>
                <ul class="space-y-2">
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <span class="text-gray-700">On-site storage for construction projects</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <span class="text-gray-700">Inventory overflow storage</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <span class="text-gray-700">International cargo shipping</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <span class="text-gray-700">Container modification projects</span>
                  </li>
                </ul>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-3">What's Included</h3>
                <ul class="space-y-2">
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">Complete container unit</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">Valid CSC plate</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">Lock box and locks</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-green-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-gray-700">Delivery coordination</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <section class="bg-white py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-8">Related Products</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {relatedProducts.map(related => {
              const relatedCondition = getProductCondition(related);
              const relatedSize = getContainerSize(related);
              const relatedImage = related.images?.[0]?.src || 'https://via.placeholder.com/400x300';

              return (
                <a href={`/products/${related.slug}`} class="group">
                  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="aspect-[4/3] relative overflow-hidden bg-gray-100">
                      <img
                        src={relatedImage}
                        alt={related.name}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                      <div class="absolute top-3 left-3">
                        <span class={`
                          inline-block px-2 py-1 text-xs font-semibold rounded-full
                          ${relatedCondition === 'New' ? 'bg-green-100 text-green-800' :
                            relatedCondition === 'Used' ? 'bg-yellow-100 text-yellow-800' :
                            'bg-blue-100 text-blue-800'}
                        `}>
                          {relatedCondition}
                        </span>
                      </div>
                    </div>
                    <div class="p-4">
                      <h3 class="text-sm font-semibold text-gray-900 mb-1 group-hover:text-blue-600 line-clamp-2">
                        {related.name}
                      </h3>
                      <p class="text-lg font-bold text-gray-900">{formatPrice(related.price)}</p>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ Section -->
    <section class="bg-gray-50 py-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-6 py-4 cursor-pointer font-medium text-gray-900 hover:text-blue-600">
              What condition is this container in?
            </summary>
            <div class="px-6 pb-4 text-gray-600">
              This container is in {condition.toLowerCase()} condition. {
                condition === 'Used' ? 'It has been previously used for shipping but is still structurally sound and watertight.' :
                condition === 'New' ? 'It is brand new, never used for shipping, and in pristine condition.' :
                'It has been professionally refurbished to ensure structural integrity and weather resistance.'
              } All our containers are thoroughly inspected before delivery.
            </div>
          </details>

          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-6 py-4 cursor-pointer font-medium text-gray-900 hover:text-blue-600">
              How is the container delivered?
            </summary>
            <div class="px-6 pb-4 text-gray-600">
              Containers are delivered via specialized trucks with crane or tilt-bed capabilities. The delivery site must have adequate space for the truck to maneuver and a level surface for placement. Our delivery team will coordinate with you to ensure smooth delivery.
            </div>
          </details>

          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-6 py-4 cursor-pointer font-medium text-gray-900 hover:text-blue-600">
              Can I modify this container?
            </summary>
            <div class="px-6 pb-4 text-gray-600">
              Yes, shipping containers can be modified for various uses including offices, homes, and storage units. Common modifications include adding windows, doors, insulation, electrical systems, and HVAC. We recommend working with experienced container modification professionals.
            </div>
          </details>

          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-6 py-4 cursor-pointer font-medium text-gray-900 hover:text-blue-600">
              What are the payment options?
            </summary>
            <div class="px-6 pb-4 text-gray-600">
              We accept wire transfers, certified checks, and offer financing options through our partners. A deposit is typically required to secure your order, with the balance due before delivery. Contact us for specific payment arrangements.
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::after {
    content: '+';
    float: right;
    font-size: 1.5rem;
    font-weight: 300;
    color: #6b7280;
  }

  details[open] summary::after {
    content: '−';
  }
</style>

<script>
  import { cart } from '../../lib/cart.js';

  // Quantity controls
  const quantityInput = document.getElementById('quantity');
  const decreaseBtn = document.getElementById('decrease-qty');
  const increaseBtn = document.getElementById('increase-qty');
  const addToCartBtn = document.getElementById('add-to-cart');

  // Decrease quantity
  decreaseBtn?.addEventListener('click', () => {
    const currentValue = parseInt(quantityInput.value) || 1;
    if (currentValue > 1) {
      quantityInput.value = currentValue - 1;
    }
  });

  // Increase quantity
  increaseBtn?.addEventListener('click', () => {
    const currentValue = parseInt(quantityInput.value) || 1;
    quantityInput.value = currentValue + 1;
  });

  // Validate input
  quantityInput?.addEventListener('change', () => {
    const value = parseInt(quantityInput.value) || 1;
    if (value < 1) {
      quantityInput.value = 1;
    }
  });

  // Add to cart
  addToCartBtn?.addEventListener('click', () => {
    const productData = JSON.parse(addToCartBtn.dataset.product);
    const quantity = parseInt(quantityInput.value) || 1;

    cart.addItem(productData, quantity);

    // Show success message
    const originalText = addToCartBtn.innerHTML;
    addToCartBtn.innerHTML = `
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      Added to Cart!
    `;
    addToCartBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
    addToCartBtn.classList.add('bg-green-700');

    setTimeout(() => {
      addToCartBtn.innerHTML = originalText;
      addToCartBtn.classList.remove('bg-green-700');
      addToCartBtn.classList.add('bg-green-600', 'hover:bg-green-700');
    }, 2000);
  });
</script>
