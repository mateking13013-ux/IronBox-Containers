---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="Order Confirmation - IronBox Containers">
  <Header />
  <main class="pt-32 pb-20 min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-lg shadow-sm p-8">
        <!-- Success Icon -->
        <div class="text-center mb-6">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Order Request Submitted!</h1>
          <p class="text-gray-600">Thank you for your interest in our shipping containers.</p>
        </div>

        <!-- Order Details -->
        <div class="border-t border-b py-6 mb-6">
          <div class="space-y-4">
            <div>
              <p class="text-sm text-gray-500 mb-1">Order Number</p>
              <p class="font-semibold text-lg" id="order-number">-</p>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">Submitted On</p>
              <p class="font-medium" id="order-date">-</p>
            </div>
          </div>
        </div>

        <!-- What's Next -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold mb-4">What Happens Next?</h2>
          <div class="space-y-4">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-sm font-semibold text-blue-600">1</div>
              <div>
                <h3 class="font-semibold mb-1">Order Review</h3>
                <p class="text-gray-600 text-sm">Our team will review your order request within 1-2 business hours during normal business hours.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-sm font-semibold text-blue-600">2</div>
              <div>
                <h3 class="font-semibold mb-1">Shipping Quote</h3>
                <p class="text-gray-600 text-sm">We'll calculate shipping costs based on your location and send you a detailed quote.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-sm font-semibold text-blue-600">3</div>
              <div>
                <h3 class="font-semibold mb-1">Final Confirmation</h3>
                <p class="text-gray-600 text-sm">Once you approve the quote, we'll process your order and schedule delivery.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="bg-gray-50 rounded-lg p-6 mb-6">
          <h2 class="text-lg font-semibold mb-4">Order Summary</h2>
          <div id="order-items" class="space-y-3 mb-4">
            <!-- Order items will be inserted here -->
          </div>
          <div class="border-t pt-4">
            <div class="flex justify-between font-semibold">
              <span>Subtotal</span>
              <span id="order-total">R0.00</span>
            </div>
            <p class="text-xs text-gray-500 mt-2">* Shipping costs will be calculated and included in your quote</p>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-blue-50 rounded-lg p-6 mb-6">
          <h3 class="font-semibold mb-2">Need immediate assistance?</h3>
          <p class="text-sm text-gray-700 mb-3">Our sales team is available Monday-Friday, 9AM-6PM CST</p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <a href="tel:+27112345678" class="text-blue-600 hover:underline">+27 11 234 5678</a>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <a href="mailto:sales@ironboxcontainers.com" class="text-blue-600 hover:underline">sales@ironboxcontainers.com</a>
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/shop" class="flex-1 text-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-md hover:bg-blue-700 transition duration-200">
            Continue Shopping
          </a>
          <button onclick="window.print()" class="flex-1 px-6 py-3 border-2 border-gray-300 text-gray-700 font-semibold rounded-md hover:bg-gray-50 transition duration-200">
            Print Order
          </button>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>

<script>
  // Load order details
  function loadOrderConfirmation() {
    const urlParams = new URLSearchParams(window.location.search);
    const orderId = urlParams.get('id');
    const orderKey = urlParams.get('key');

    if (!orderId) {
      // Fallback to localStorage if no URL params (legacy support)
      const order = JSON.parse(localStorage.getItem('lastOrder') || '{}');
      if (order.orderNumber) {
        displayOrder(order);
      } else {
        window.location.href = '/shop';
      }
      return;
    }

    // Display order number from URL
    const orderNumberEl = document.getElementById('order-number');
    if (orderNumberEl) orderNumberEl.textContent = `Order #${orderId}`;

    // Display current date
    const orderDateEl = document.getElementById('order-date');
    if (orderDateEl) {
      const date = new Date();
      orderDateEl.textContent = date.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    // We don't have item details in URL, so we show a generic success message
    // or try to recover from localStorage if it matches
    const itemsContainer = document.getElementById('order-items');
    const totalEl = document.getElementById('order-total');
    
    if (itemsContainer) {
      itemsContainer.innerHTML = `
        <div class="text-center py-4 text-gray-500">
          <p>Order details have been emailed to you.</p>
        </div>
      `;
    }
    
    if (totalEl) {
      totalEl.textContent = 'Pending Payment Verification';
    }
  }

  function displayOrder(order) {
    // ... (keep existing display logic if needed for fallback)
    const orderNumberEl = document.getElementById('order-number');
    if (orderNumberEl) orderNumberEl.textContent = order.orderNumber;
    
    // ... rest of display logic
  }

  // Load on page load
  loadOrderConfirmation();
</script>
