---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllProducts, formatPrice, getProductCondition, getContainerSize, parseProductSpecs } from '../../lib/woocommerce.js';

// Tell Astro which paths to pre-render
export function getStaticPaths() {
  return [
    { params: { slug: 'houston-tx-20ft-containers-construction' } }
  ];
}

const { slug } = Astro.params;

// Fetch 3 featured 20ft products
const allProducts = await getAllProducts();
const featuredProducts = allProducts.filter(product => getContainerSize(product) === '20ft').slice(0, 3);

// Policy sidebar data
const allPolicies = [
	{ name: "Privacy Policy", href: "/privacy-policy" },
	{ name: "Terms of Service", href: "/terms-of-service" },
	{ name: "Return & Warranty Policy", href: "/return-policy" },
	{ name: "Shipping & Installation Policy", href: "/shipping-policy" },
	{ name: "Cookie Policy", href: "/cookie-policy" },
	{ name: "Accessibility Policy", href: "/accessibility" },
	{ name: "Data Protection Policy", href: "/data-protection" },
	{ name: "GDPR Compliance", href: "/gdpr" }
];

const categories = [
	{ name: "20ft Used Containers", href: "/categories/20ft-used-shipping-containers" },
	{ name: "20ft New Containers", href: "/categories/20ft-new-shipping-containers" },
	{ name: "40ft New Containers", href: "/categories/40ft-new-shipping-containers" },
	{ name: "40ft Used Containers", href: "/categories/40ft-used-shipping-containers" },
	{ name: "10ft Used Containers", href: "/categories/10-ft-used-shipping-containers" },
	{ name: "10ft New Containers", href: "/categories/10ft-new-shipping-containers" },
	{ name: "Modified Containers", href: "/categories/modified-containers" },
	{ name: "Refrigerated Containers", href: "/categories/refrigerated-shipping-containers" },
	{ name: "Guard Booths & Shacks", href: "/categories/guard-booths-shacks-houses" },
	{ name: "Portable Offices", href: "/categories/portable-site-office-containers" }
];

const contactDetails = {
	phone: "+27 11 234 5678",
	email: "sales@ironboxcontainers.co.za",
	address: "1421 Horizon Parkway, Austin, TX 73301"
};
