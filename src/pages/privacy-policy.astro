---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PrivacyPolicyPage from '../components/support/PrivacyPolicyPage.astro';
import PolicyPageLayout from '../components/policy/PolicyPageLayout.astro';
---

<MainLayout title="Privacy Policy – IronBox Containers" description="Learn how IronBox Containers collects, uses, and protects your personal information.">
  <Header />
  <PolicyPageLayout
    title="Privacy Policy"
    lastUpdated="Updated January 24, 2025"
  >
    <PrivacyPolicyPage />
    <div class="mt-8 pt-8 border-t border-border">
      <h3 class="text-lg font-semibold text-foreground mb-4">Contact Us</h3>
      <p class="text-muted-foreground mb-2">If you have questions about this policy, please contact us:</p>
      <ul class="space-y-2 text-muted-foreground">
        <li><strong>IronBox Containers</strong></li>
        <li>15 Electron Avenue, Isando</li>
        <li>Kempton Park, Gauteng, 1600</li>
        <li>South Africa</li>
        <li>Email: <a href="mailto:support@ironboxcontainers.co.za" class="text-primary hover:underline">support@ironboxcontainers.co.za</a></li>
        <li>Phone: <a href="tel:+27112345678" class="text-primary hover:underline">+27 11 234 5678</a></li>
      </ul>
    </div>
  </PolicyPageLayout>
  <Footer />
</MainLayout>
