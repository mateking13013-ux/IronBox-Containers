---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactPage from '../components/support/ContactPage.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "IronBox Containers",
  "image": "/images/branding/ironbox-logo.png",
  "telephone": "+27-11-234-5678",
  "email": "support@ironboxcontainers.co.za",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "15 Electron Avenue, Isando",
    "addressLocality": "Kempton Park",
    "addressRegion": "GP",
    "postalCode": "1600",
    "addressCountry": "ZA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "-26.1413",
    "longitude": "28.2340"
  },
  "url": "https://ironboxcontainers.co.za/contact",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "16:00"
    }
  ]
};
---

<MainLayout title="Contact IronBox Containers" description="Speak with the IronBox Containers concierge team about container pools, prefab homes, and custom projects.">
  <slot slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
  </slot>
  <Header />
  <main class="pb-16">
    <ContactPage />
  </main>
  <Footer />
</MainLayout>
