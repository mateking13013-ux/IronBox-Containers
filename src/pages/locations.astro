---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

// Mock locations data - replace with WordPress data later
const locations = [
  { name: 'Johannesburg', slug: 'johannesburg', state: 'GP', phone: '+27 11 234 5678', containers: '180+', delivery: 'Same Day', rating: 4.8 },
  { name: 'Cape Town', slug: 'cape-town', state: 'WC', phone: '+27 21 234 5678', containers: '150+', delivery: 'Next Day', rating: 4.9 },
  { name: 'Durban', slug: 'durban', state: 'KZN', phone: '+27 31 234 5678', containers: '120+', delivery: 'Same Day', rating: 4.7 },
  { name: 'Pretoria', slug: 'pretoria', state: 'GP', phone: '+27 12 234 5678', containers: '130+', delivery: 'Same Day', rating: 4.8 },
  { name: 'Port Elizabeth', slug: 'port-elizabeth', state: 'EC', phone: '+27 41 234 5678', containers: '100+', delivery: 'Next Day', rating: 4.6 },
  { name: 'Bloemfontein', slug: 'bloemfontein', state: 'FS', phone: '+27 51 234 5678', containers: '85+', delivery: 'Next Day', rating: 4.7 },
  { name: 'East London', slug: 'east-london', state: 'EC', phone: '+27 43 234 5678', containers: '75+', delivery: 'Next Day', rating: 4.6 },
  { name: 'Nelspruit', slug: 'nelspruit', state: 'MP', phone: '+27 13 234 5678', containers: '70+', delivery: 'Next Day', rating: 4.7 },
  { name: 'Polokwane', slug: 'polokwane', state: 'LP', phone: '+27 15 234 5678', containers: '65+', delivery: 'Next Day', rating: 4.6 },
  { name: 'Rustenburg', slug: 'rustenburg', state: 'NW', phone: '+27 14 234 5678', containers: '80+', delivery: 'Next Day', rating: 4.7 }
];

// Single container inquiry to perfect design - replace with WordPress data later
const containerInquiries = [
  {
    id: 'RFQ-2024-001',
    title: '20ft Shipping Containers for Construction Johannesburg Gauteng',
    buyer: 'IronBox Containers',
    country: 'South Africa',
    category: 'Standard Containers',
    quantity: '5 units',
    posted: '2 hours ago',
    slug: 'houston-tx-20ft-containers-construction',
    description: 'Premium 20ft standard containers perfect for construction sites and building projects. Wind & water tight with CSC certification available. Ideal for tool storage, equipment protection, and temporary office spaces on construction sites throughout Johannesburg.',
    budget: 'R215,000 - R270,000',
    delivery: 'Johannesburg, Gauteng',
    seo_description: 'Find 20ft shipping containers for construction in Johannesburg Gauteng. New and used containers with fast delivery. Perfect for construction sites, tool storage, and building projects.',
    keywords: ['20ft containers', 'construction containers', 'Johannesburg shipping containers', 'building site storage', 'tool storage containers', 'used containers Johannesburg']
  }
];

const pageTitle = 'Shipping Container Trade Inquiries';
const pageDescription = 'Browse verified shipping container leads and RFQs from buyers worldwide. Connect with businesses seeking containers for all applications.';
---

<MainLayout 
  title={pageTitle}
  description={pageDescription}
>
  <Header />
      <!-- Search Section Only -->
      <section class="py-16 px-6 bg-gray-50">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl font-bold text-gray-900 mb-4" style="font-family: 'Oswald', sans-serif;">
            Find Container Trade Leads
          </h1>
          <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
            Browse our available shipping containers for sale. Find the perfect container for your needs with detailed specifications and competitive pricing across all types and sizes.
          </p>
          
          <div class="max-w-2xl mx-auto">
            <div class="relative">
              <input 
                type="text" 
                placeholder="Search container inquiries by type, location, or keywords..."
                class="w-full px-6 py-4 text-lg border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                id="inquirySearch"
              >
              <button class="absolute right-2 top-2 bg-amber-600 text-white px-6 py-2 rounded-md hover:bg-amber-700 transition-colors">
                Search
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- Container Inquiries Archive -->
      <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="bg-gray-50 rounded-lg border border-gray-200 p-4">
          <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <!-- Main Content - Trade Inquiries -->
            <div class="lg:col-span-3">
              <div class="space-y-4" id="inquiriesGrid">
              {containerInquiries.map((inquiry) => (
                <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-all hover:border-amber-300">
                  <!-- Header -->
                  <div class="bg-amber-600 text-white px-3 py-2">
                    <div class="flex justify-between items-center">
                      <div>
                        <h3 class="text-sm font-semibold mb-1">
                          <a href={`/containers/${inquiry.slug}`} class="hover:underline">{inquiry.title}</a>
                        </h3>
                        <div class="text-amber-100 text-xs">
                          <span>Posted: {inquiry.posted}</span>
                        </div>
                      </div>
                      <div class="bg-white/20 px-2 py-1 rounded-full text-xs">
                        {inquiry.category}
                      </div>
                    </div>
                  </div>
                  
                  <!-- Content -->
                  <div class="p-3">
                    <!-- SEO-Focused Content -->
                    <div class="flex items-start gap-3">
                      
                      <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          <div class="font-semibold text-xs text-gray-900">{inquiry.buyer}</div>
                          <div class="text-xs text-gray-500">• {inquiry.delivery}</div>
                        </div>
                        
                        <!-- Description -->
                        <p class="text-gray-600 text-xs leading-relaxed mb-2">
                          {inquiry.description}
                        </p>
                        
                        <!-- Keywords -->
                        <div class="flex flex-wrap gap-1 mb-2">
                          {inquiry.keywords.map((keyword, index) => (
                            <span key={index} class="px-2 py-1 bg-amber-50 text-amber-700 rounded text-xs">
                              {keyword}
                            </span>
                          ))}
                        </div>
                        
                        <!-- Details Row -->
                        <div class="flex items-center justify-between text-xs mb-3">
                          <div>
                            <span class="text-gray-500">Quantity:</span>
                            <span class="font-medium text-gray-900 ml-1">{inquiry.quantity}</span>
                          </div>
                          <div class="flex items-center gap-2">
                            <span class="text-gray-500">Budget:</span>
                            <span class="font-medium text-gray-900 ml-1">{inquiry.budget}</span>
                            <a href={`/containers/${inquiry.slug}`} class="inline-flex items-center px-2 py-1 bg-amber-500 text-white text-xs font-medium rounded hover:bg-amber-600 transition-colors">
                              Read More
                            </a>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    
                  </div>
                </div>
              ))}
            </div>
            </div>

            <!-- Sidebar - Quick Actions & Safety -->
            <div class="space-y-6">
              <!-- Quick Actions Section -->
              <div class="bg-white rounded-lg border border-gray-200 p-4">
                <h3 class="text-sm font-semibold text-gray-900 mb-4">Quick Actions</h3>
                
                <!-- Request Quote & Contact Us -->
              <div class="space-y-2 mb-3 pb-3 border-b border-gray-300">
                <button onclick="window.location.href='/contact'" class="w-full bg-amber-700 text-white py-2 px-3 rounded-md hover:bg-amber-800 transition-colors font-medium flex items-center justify-center gap-2 text-sm">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                  Request Quote
                </button>
                <div class="grid grid-cols-2 gap-2">
                  <button onclick="window.location.href='mailto:sales@example.com'" class="w-full bg-amber-100 text-amber-700 py-2 px-2 rounded-md hover:bg-amber-200 transition-colors font-medium text-xs flex items-center justify-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    Email Us
                  </button>
                  <button onclick="window.location.href='tel:555-0123'" class="w-full bg-amber-100 text-amber-700 py-2 px-2 rounded-md hover:bg-amber-200 transition-colors font-medium text-xs flex items-center justify-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    Send SMS
                  </button>
                </div>
              </div>
              
              <!-- Request Service -->
              <button onclick="window.location.href='/contact'" class="w-full bg-amber-500 text-white py-2 px-3 rounded-md hover:bg-amber-600 transition-colors font-medium flex items-center justify-center gap-2 text-sm mb-2">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Request Service
              </button>
              
              <!-- All Shipping Containers -->
                <button onclick="window.location.href='/shop'" class="w-full bg-amber-100 text-amber-700 py-2 px-3 rounded-md hover:bg-amber-200 transition-colors font-medium text-sm">
                All Shipping Containers
              </button>
              
              
            </div>

            
          </div>
        </div>
      </div>
    </div>

      <!-- CTA Section -->
      <section class="bg-amber-600 text-white py-16 px-6">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <h2 class="text-3xl font-bold">Don't See Your City Listed?</h2>
          <p class="text-lg opacity-90">
            We're expanding rapidly! Contact us to find out if we serve your area or to request service in your location.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="tel:555-0123" class="inline-flex items-center justify-center px-8 py-4 bg-white text-amber-600 text-lg font-medium rounded-lg hover:bg-gray-100 transition-colors">
              Call (555) 0123
            </a>
            <button class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white text-lg font-medium rounded-lg hover:bg-white hover:text-amber-600 transition-colors">
              Request Service
            </button>
          </div>
        </div>
      </section>

      <Footer />
    </MainLayout>

    <!-- Search Functionality -->
    <script>
      document.getElementById('inquirySearch')?.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const inquiryCards = document.querySelectorAll('#inquiriesGrid > div');
        
        inquiryCards.forEach(card => {
          const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
          const description = card.querySelector('.text-gray-700')?.textContent.toLowerCase() || '';
          const buyer = card.querySelector('.font-semibold')?.textContent.toLowerCase() || '';
          const category = card.querySelector('.bg-white\\/20')?.textContent.toLowerCase() || '';
          
          if (title.includes(searchTerm) || description.includes(searchTerm) || buyer.includes(searchTerm) || category.includes(searchTerm)) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      });
    </script>
