---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    category: 'Ordering & Delivery',
    questions: [
      {
        q: 'How fast is delivery?',
        a: 'We typically deliver standard containers within 5-10 business days nationwide. Custom builds may take 4-8 weeks depending on complexity.',
      },
      {
        q: 'Do you deliver to residential addresses?',
        a: 'Yes, as long as there is sufficient space for a tilt-bed truck to maneuver and offload. We require at least 14 feet of overhead clearance and 40-60 feet of straight-line access.',
      },
      {
        q: 'What are the delivery requirements?',
        a: 'You need a flat, level surface (gravel, concrete, or compacted earth), clear access for our delivery truck, and any necessary permits for placement.',
      },
      {
        q: 'Can I track my order?',
        a: 'Yes! Once your order ships, you will receive tracking information via email. You can also contact our support team at +27 11 234 5678 for real-time updates.',
      },
    ],
  },
  {
    category: 'Products & Customization',
    questions: [
      {
        q: 'What sizes do you offer?',
        a: 'We offer 10ft, 20ft, and 40ft containers in various configurations including standard height and high cube (9.5ft tall) options.',
      },
      {
        q: 'Can I customize my container?',
        a: 'Absolutely! We offer custom modifications including windows, doors, insulation, electrical, plumbing, HVAC, and interior finishes. Contact us to discuss your project.',
      },
      {
        q: 'Can I inspect the container before buying?',
        a: 'Yes, we can provide photos of the exact unit you will receive. For local customers, we can arrange in-person inspections at our facility.',
      },
      {
        q: 'What condition are your containers?',
        a: 'We offer new (one-trip), cargo-worthy, and wind & water tight containers. Each listing specifies the condition grade.',
      },
    ],
  },
  {
    category: 'Pricing & Payment',
    questions: [
      {
        q: 'What payment methods do you accept?',
        a: 'We accept all major credit cards, PayPal, bank transfers, and financing options for qualified buyers.',
      },
      {
        q: 'Do you offer financing?',
        a: 'Yes, we partner with financing providers to offer flexible payment plans. Contact our sales team to learn more about available options.',
      },
      {
        q: 'Are there any hidden fees?',
        a: 'No hidden fees. Our quotes include the container price and delivery to your location. Any optional services (modifications, permits, crane service) are clearly itemized.',
      },
      {
        q: 'Can I get a quote?',
        a: 'Yes! Fill out our contact form or call +27 11 234 5678 to receive a detailed quote for your specific needs.',
      },
    ],
  },
  {
    category: 'Returns & Warranty',
    questions: [
      {
        q: 'What is your return policy?',
        a: 'We accept returns of standard, non-customized containers within 30 days of delivery. A 15% restocking fee applies. Custom fabricated units are final sale once production begins.',
      },
      {
        q: 'Do you offer warranties?',
        a: 'Yes, all new containers come with a structural warranty. Custom builds include warranties on workmanship and installed systems. Specific terms vary by product.',
      },
      {
        q: 'What if my container arrives damaged?',
        a: 'Document any damage with photos and notify support@ironboxcontainers.com within 48 hours of delivery. We will arrange for inspection and resolution.',
      },
      {
        q: 'Are deposits refundable?',
        a: 'Deposits on build-to-order units are non-refundable but transferable to future projects for 12 months.',
      },
    ],
  },
  {
    category: 'Site Preparation & Installation',
    questions: [
      {
        q: 'Do I need a foundation?',
        a: 'Containers can be placed on level ground, concrete piers, or a full foundation. We recommend consulting with a local contractor for site-specific guidance.',
      },
      {
        q: 'Do I need permits?',
        a: 'Permit requirements vary by location. We provide documentation to support your permit applications, but obtaining permits is the customer\'s responsibility.',
      },
      {
        q: 'Can you help with installation?',
        a: 'We offer delivery and placement. For complex installations (utilities, HVAC, plumbing), we can recommend licensed contractors in your area.',
      },
      {
        q: 'What about utilities (water, electric, etc.)?',
        a: 'We can pre-wire and pre-plumb containers, but final utility connections must be completed by licensed local professionals according to code.',
      },
    ],
  },
  {
    category: 'Support & Contact',
    questions: [
      {
        q: 'What are your business hours?',
        a: 'Monday-Friday: 8AM-6PM | Saturday: 9AM-4PM (Central Time). We are closed on Sundays and major holidays.',
      },
      {
        q: 'How can I contact customer support?',
        a: 'Call us at +27 11 234 5678 or email support@ironboxcontainers.com. We typically respond within 24 business hours.',
      },
      {
        q: 'Where are you located?',
        a: 'Our main facility is at 15 Electron Avenue, Isando, Kempton Park, Gauteng, 1600. We serve customers nationwide.',
      },
      {
        q: 'Do you have a showroom?',
        a: 'Yes! Visit our Kempton Park, GP facility to see various container models and configurations. Call ahead to schedule a tour.',
      },
    ],
  },
];
---

<MainLayout title="Frequently Asked Questions – IronBox Containers" description="Get answers to common questions about shipping containers, delivery, pricing, customization, and more.">
  <Header />

  <section class="bg-background text-foreground">
    <!-- Hero Section -->
    <div class="border-b border-border bg-gradient-to-r from-primary/10 via-background to-accent/10">
      <div class="mx-auto max-w-4xl px-4 py-16 text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">Help Center</span>
        <h1 class="mt-4 text-4xl font-semibold">Frequently Asked Questions</h1>
        <p class="mt-3 text-base text-muted-foreground">Find quick answers to common questions about our shipping containers, delivery, customization, and services.</p>
      </div>
    </div>

    <!-- FAQ Content -->
    <div class="mx-auto max-w-4xl px-4 py-16">
      <div class="space-y-12">
        {faqs.map((section) => (
          <div>
            <h2 class="mb-6 text-2xl font-semibold text-foreground border-b border-border pb-3">{section.category}</h2>
            <div class="space-y-6">
              {section.questions.map((faq) => (
                <div class="rounded-xl border border-border bg-card p-6 shadow-sm transition hover:shadow-md">
                  <h3 class="text-lg font-semibold text-foreground mb-2">{faq.q}</h3>
                  <p class="text-sm text-muted-foreground leading-relaxed">{faq.a}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Contact CTA -->
      <div class="mt-16 rounded-2xl border border-border bg-muted/30 p-8 text-center">
        <h2 class="text-2xl font-semibold text-foreground">Still have questions?</h2>
        <p class="mt-2 text-muted-foreground">Our team is here to help you find the perfect container solution.</p>
        <div class="mt-6 flex flex-wrap justify-center gap-4">
          <a href="tel:+27112345678" class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75C2.25 5.784 3.034 5 4 5h2.25c.85 0 1.566.616 1.715 1.454l.381 2.09a1.725 1.725 0 01-.436 1.483l-1.1 1.1a16.5 16.5 0 007.542 7.542l1.1-1.1c.39-.39.956-.566 1.483-.436l2.09.381A1.725 1.725 0 0119 17.75V20c0 .966-.784 1.75-1.75 1.75H17c-8.837 0-16-7.163-16-16V6.75z" /></svg>
            Call +27 11 234 5678
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-full border border-border px-6 py-3 text-sm font-semibold text-foreground transition hover:bg-muted">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-6.9 4.143a2.25 2.25 0 01-2.26 0L3.57 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>
