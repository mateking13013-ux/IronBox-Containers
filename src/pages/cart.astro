---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="Shopping Cart - IronBox Containers" description="View your cart and proceed to checkout">
  <Header />
  <main class="min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Cart Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Shopping Cart</h1>
        <p class="mt-2 text-gray-600">
          <span id="cart-count">0</span> items in your cart
        </p>
      </div>

      <div class="lg:grid lg:grid-cols-12 lg:gap-8">
        <!-- Cart Items -->
        <div class="lg:col-span-8">
          <div id="cart-empty" class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center hidden">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
            <h2 class="text-lg font-semibold text-gray-900 mb-2">Your cart is empty</h2>
            <p class="text-gray-600 mb-6">Add some containers to get started!</p>
            <a href="/shop" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors">
              Continue Shopping
            </a>
          </div>

          <div id="cart-items" class="space-y-4">
            <!-- Cart items will be rendered here -->
          </div>
        </div>

        <!-- Cart Summary -->
        <div class="lg:col-span-4 mt-8 lg:mt-0">
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 sticky top-24">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Order Summary</h2>

            <div class="space-y-3 mb-6">
              <div class="flex justify-between text-gray-600">
                <span>Subtotal</span>
                <span id="cart-subtotal">R0</span>
              </div>
              <div class="flex justify-between text-gray-600">
                <span>Shipping</span>
                <span class="text-sm">Calculated at checkout</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="text-lg font-semibold text-gray-900">Total</span>
                <span class="text-lg font-semibold text-gray-900" id="cart-total">R0</span>
              </div>
            </div>

            <div class="space-y-3">
              <a href="/checkout" id="checkout-button" class="block w-full px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors text-center">
                Proceed to Checkout
              </a>
              <a href="/shop" class="block w-full px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg border-2 border-blue-600 hover:bg-blue-50 transition-colors text-center">
                Continue Shopping
              </a>
            </div>

            <div class="mt-6 pt-6 border-t">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Customer Support</h3>
              <div class="space-y-2 text-sm text-gray-600">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  <a href="tel:+27112345678" class="hover:text-blue-600">+27 11 234 5678</a>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <a href="mailto:sales@ironboxcontainers.co.za" class="hover:text-blue-600">sales@ironboxcontainers.co.za</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>

<script>
  import { cart } from '../lib/cart.js';

  function formatPrice(price) {
    return 'R' + new Intl.NumberFormat('en-ZA', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(price);
  }

  function renderCart() {
    const cartItems = cart.getCart();
    const cartItemsContainer = document.getElementById('cart-items');
    const cartEmpty = document.getElementById('cart-empty');
    const cartCount = document.getElementById('cart-count');
    const cartSubtotal = document.getElementById('cart-subtotal');
    const cartTotal = document.getElementById('cart-total');
    const checkoutButton = document.getElementById('checkout-button');

    if (!cartItemsContainer) return;

    if (cartItems.length === 0) {
      cartItemsContainer.innerHTML = '';
      cartEmpty?.classList.remove('hidden');
      if (cartCount) cartCount.textContent = '0';
      if (cartSubtotal) cartSubtotal.textContent = 'R0';
      if (cartTotal) cartTotal.textContent = 'R0';
      if (checkoutButton) {
        checkoutButton.classList.add('opacity-50', 'pointer-events-none');
      }
      return;
    }

    cartEmpty?.classList.add('hidden');
    if (checkoutButton) {
      checkoutButton.classList.remove('opacity-50', 'pointer-events-none');
    }

    // Update count
    const totalCount = cart.getItemCount();
    if (cartCount) cartCount.textContent = totalCount.toString();

    // Update total
    const total = cart.getTotal();
    if (cartSubtotal) cartSubtotal.textContent = formatPrice(total);
    if (cartTotal) cartTotal.textContent = formatPrice(total);

    // Render items
    cartItemsContainer.innerHTML = cartItems.map(item => `
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex gap-6">
          <!-- Product Image -->
          <div class="w-24 h-24 flex-shrink-0">
            ${item.image ?
              `<img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover rounded-lg">` :
              `<div class="w-full h-full bg-gray-200 rounded-lg flex items-center justify-center">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>`
            }
          </div>

          <!-- Product Details -->
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-900 mb-1">
              <a href="/products/${item.slug}" class="hover:text-blue-600">${item.name}</a>
            </h3>
            <p class="text-sm text-gray-600 mb-3">SKU: ${item.sku}</p>

            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <!-- Quantity Controls -->
                <div class="flex items-center border border-gray-300 rounded-lg">
                  <button
                    onclick="updateQuantity(${item.id}, ${item.quantity - 1})"
                    class="px-3 py-1 text-gray-600 hover:bg-gray-100 rounded-l-lg transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                    </svg>
                  </button>
                  <input
                    type="number"
                    value="${item.quantity}"
                    onchange="updateQuantity(${item.id}, parseInt(this.value))"
                    min="1"
                    class="w-12 px-1 py-1 text-center border-x border-gray-300 focus:outline-none"
                  />
                  <button
                    onclick="updateQuantity(${item.id}, ${item.quantity + 1})"
                    class="px-3 py-1 text-gray-600 hover:bg-gray-100 rounded-r-lg transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                  </button>
                </div>

                <!-- Remove Button -->
                <button
                  onclick="removeItem(${item.id})"
                  class="text-red-600 hover:text-red-700 text-sm font-medium"
                >
                  Remove
                </button>
              </div>

              <!-- Price -->
              <div class="text-right">
                <p class="text-lg font-semibold text-gray-900">${formatPrice(item.price * item.quantity)}</p>
                <p class="text-sm text-gray-500">${formatPrice(item.price)} each</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Global functions for cart actions
  window.updateQuantity = (productId, quantity) => {
    cart.updateQuantity(productId, quantity);
    renderCart();
  };

  window.removeItem = (productId) => {
    cart.removeItem(productId);
    renderCart();
  };

  // Initial render
  renderCart();

  // Listen for cart updates from other pages
  window.addEventListener('cartUpdated', renderCart);
</script>
