---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TermsPage from '../components/support/TermsPage.astro';
import PolicyPageLayout from '../components/policy/PolicyPageLayout.astro';
---

<MainLayout title="Terms of Service – IronBox Containers" description="Review the terms and conditions for purchasing shipping containers from IronBox Containers.">
  <Header />
  <PolicyPageLayout
    title="Terms of Service"
    lastUpdated="Updated January 24, 2025"
  >
    <TermsPage />
    <div class="mt-8 pt-8 border-t border-border">
      <h3 class="text-lg font-semibold text-foreground mb-4">Contact Information</h3>
      <p class="text-muted-foreground mb-2">Questions about the Terms of Service should be sent to us at:</p>
      <ul class="space-y-2 text-muted-foreground">
        <li><strong>IronBox Containers</strong></li>
        <li>15 Electron Avenue, Isando</li>
        <li>Kempton Park, Gauteng, 1600</li>
        <li>South Africa</li>
        <li>Email: <a href="mailto:support@ironboxcontainers.co.za" class="text-primary hover:underline">support@ironboxcontainers.co.za</a></li>
        <li>Phone: <a href="tel:+27112345678" class="text-primary hover:underline">+27 11 234 5678</a></li>
      </ul>
    </div>
  </PolicyPageLayout>
  <Footer />
</MainLayout>
