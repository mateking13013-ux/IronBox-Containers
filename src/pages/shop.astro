---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CleanShopArchive from '../components/shop/CleanShopArchive.astro';

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Shop All Shipping Containers",
  "description": "Browse our complete inventory of ISO certified shipping containers. New, used, and refurbished containers available with nationwide delivery.",
  "url": "https://ironboxcontainers.com/shop",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://ironboxcontainers.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Shop",
        "item": "https://ironboxcontainers.com/shop"
      }
    ]
  }
};
---

<MainLayout title="Shop Shipping Containers – IronBox Containers" description="Browse our complete inventory of ISO certified shipping containers. New, used, and refurbished containers available with nationwide delivery.">
  <slot slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)}></script>
  </slot>
  <Header />
  <main>
    <CleanShopArchive />
  </main>
  <Footer />
</MainLayout>
